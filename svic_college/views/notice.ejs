    <ul class="mobile-nav-list">
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-home"></i> Home</a></li>
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-info-circle"></i> About</a></li>
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-door-open"></i> Admission</a></li>
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-book-open"></i> Courses</a></li>
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-bell"></i> Notice Board</a></li>
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-headset"></i> Contact</a></li>
