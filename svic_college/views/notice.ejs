<script>
    // Notice Data
    const notices = [
        { id: 1, title: "Admission Open 2025-26", description: "Applications are invited for Class 11th and 12th for the academic session 2025-26. Last date to apply is 30th April 2025.", date: "15 Jan 2025", category: "important", icon: "fa-graduation-cap" },
        { id: 2, title: "Annual Examination Schedule", description: "Annual examinations for Class 10th and 12th will commence from 1st March 2025. Download the detailed timetable from student portal.", date: "10 Feb 2025", category: "exam", icon: "fa-calendar-alt" },
        { id: 3, title: "Parent-Teacher Meeting", description: "PTM for Class 10th & 12th will be held on 25th March 2025 from 9:00 AM to 2:00 PM. All parents are requested to attend.", date: "20 Feb 2025", category: "event", icon: "fa-users" },
        { id: 4, title: "Holi Vacation Announcement", description: "College will remain closed from 13th March to 17th March 2025 on account of Holi festival. Classes will resume on 18th March.", date: "25 Feb 2025", category: "holiday", icon: "fa-palette" },
        { id: 5, title: "Scholarship Application Deadline Extended", description: "Last date for scholarship application submission has been extended to 31st March 2025. Eligible students can apply online.", date: "28 Feb 2025", category: "important", icon: "fa-trophy" },
        { id: 6, title: "New Computer Lab Inauguration", description: "State-of-the-art computer lab with 50+ systems will be inaugurated on 5th March 2025 at 11:00 AM.", date: "1 Mar 2025", category: "event", icon: "fa-laptop-code" },
        { id: 7, title: "Pre-Board Exam Schedule", description: "Pre-board examinations for Class 10th and 12th will be held from 15th February to 25th February 2025.", date: "1 Feb 2025", category: "exam", icon: "fa-edit" },
        { id: 8, title: "Science Exhibition 2025", description: "Annual Science Exhibition will be organized on 12th April 2025. Interested students can register by 31st March.", date: "5 Mar 2025", category: "event", icon: "fa-microscope" },
        { id: 9, title: "Summer Vacation Notice", description: "Summer vacation for all classes will commence from 15th May 2025. College will reopen on 1st July 2025.", date: "10 Mar 2025", category: "holiday", icon: "fa-umbrella-beach" },
        { id: 10, title: "New Session Orientation", description: "Orientation program for new admissions will be held on 25th June 2025 at 10:00 AM in the college auditorium.", date: "15 Mar 2025", category: "academic", icon: "fa-chalkboard-user" },
        { id: 11, title: "Fee Submission Deadline", description: "Last date for fee submission for the academic session 2025-26 is 31st May 2025. Late fee applicable after due date.", date: "20 Mar 2025", category: "important", icon: "fa-rupee-sign" },
        { id: 12, title: "Sports Day Announcement", description: "Annual Sports Day will be celebrated on 5th April 2025. Various competitions will be organized for all classes.", date: "25 Mar 2025", category: "event", icon: "fa-futbol" }
    ];

    let currentFilter = "all";
    let currentSearch = "";

    function renderNotices() {
        let filtered = notices.filter(notice => {
            if (currentFilter !== "all" && notice.category !== currentFilter) return false;
            if (currentSearch && !notice.title.toLowerCase().includes(currentSearch.toLowerCase()) && 
                !notice.description.toLowerCase().includes(currentSearch.toLowerCase())) return false;
            return true;
        });

        // Update stats
        document.getElementById('totalNotices').innerText = filtered.length;
        document.getElementById('importantCount').innerText = notices.filter(n => n.category === 'important').length;
        document.getElementById('examCount').innerText = notices.filter(n => n.category === 'exam').length;
        document.getElementById('eventCount').innerText = notices.filter(n => n.category === 'event').length;

        const grid = document.getElementById('noticeGrid');
        const noResults = document.getElementById('noResults');

        if (filtered.length === 0) {
            grid.style.display = 'none';
            noResults.style.display = 'block';
            return;
        }

        grid.style.display = 'grid';
        noResults.style.display = 'none';

        grid.innerHTML = filtered.map(notice => `
            <div class="notice-card" onclick="showNoticeDetails(${notice.id})">
                <div class="notice-badge ${notice.category}">
                    ${notice.category === 'important' ? '⚠️ Important' : 
                      notice.category === 'academic' ? '📚 Academic' :
                      notice.category === 'exam' ? '📝 Exam' :
                      notice.category === 'event' ? '🎉 Event' : '🏖️ Holiday'}
                </div>
                <div class="notice-date">
                    <i class="far fa-calendar-alt"></i>
                    <span>${notice.date}</span>
                </div>
                <div class="notice-title">
                    ${notice.title}
                </div>
                <div class="notice-desc">
                    ${notice.description.substring(0, 120)}${notice.description.length > 120 ? '...' : ''}
                </div>
                <div class="notice-footer">
                    <a href="#" class="notice-link" onclick="event.stopPropagation(); viewDetails(${notice.id})">
                        Read More <i class="fas fa-arrow-right"></i>
                    </a>
                    <span class="download-icon"><i class="fas fa-download"></i> PDF</span>
                </div>
            </div>
        `).join('');
    }

    function viewDetails(id) {
        const notice = notices.find(n => n.id === id);
        if (notice) {
            alert(`📢 ${notice.title}\n\n📅 Date: ${notice.date}\n\n📝 ${notice.description}\n\nFor more details, please contact the college office.`);
        }
    }

    function showNoticeDetails(id) {
        viewDetails(id);
    }

    function showToast(message) {
        const toast = document.createElement('div');
        toast.innerHTML = `<div style="position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#1e1b4b;color:white;padding:12px 25px;border-radius:50px;font-size:14px;z-index:10000;box-shadow:0 5px 20px rgba(0,0,0,0.2);animation:fadeInUp 0.3s ease;">${message}</div>`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2500);
    }

    // Filter and Search Event Listeners
    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentFilter = btn.dataset.filter;
            renderNotices();
        });
    });

    document.getElementById('searchInput').addEventListener('input', (e) => {
        currentSearch = e.target.value;
        renderNotices();
    });

    // Mobile Menu Functions
    function openMobileMenu() {
        document.getElementById('mobileMenu').classList.add('active');
        document.getElementById('screenOverlay').classList.add('active');
        document.body.style.overflow = 'hidden';
    }
    
    function closeMobileMenu() {
        document.getElementById('mobileMenu').classList.remove('active');
        document.getElementById('screenOverlay').classList.remove('active');
        document.body.style.overflow = '';
    }

    // Add animation style
    const style = document.createElement('style');
    style.textContent = `@keyframes fadeInUp { from { opacity:0; transform:translateX(-50%) translateY(20px); } to { opacity:1; transform:translateX(-50%) translateY(0); } }`;
    document.head.appendChild(style);
    
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMobileMenu(); });
    window.addEventListener('resize', () => { if (window.innerWidth > 992) closeMobileMenu(); });

    // Initial Render
    renderNotices();
    
    console.log("✅ Notice Board Page Loaded - Fully Responsive & Interactive");
</script>
<%-include('partials/footer')%>
</body>
</html>