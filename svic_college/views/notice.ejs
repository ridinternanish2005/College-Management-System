    </ul>
</div>
<div class="screen-overlay" id="screenOverlay" onclick="closeMobileMenu()"></div>

<!-- PAGE HEADER -->
<div class="page-header">
    <h1><i class="fas fa-bell"></i> Notice Board</h1>
    <p>Stay updated with the latest announcements, exam schedules, events, and important notifications</p>
</div>

<div class="container">
    <!-- Filter Section -->
    <div class="filter-section">
        <div class="filter-buttons">
            <button class="filter-btn active" data-filter="all">📋 All Notices</button>
            <button class="filter-btn" data-filter="important">⚠️ Important</button>
