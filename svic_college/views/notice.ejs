<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Notice Board | SVIC Inter College</title>
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #fef9f0 0%, #fff4e8 100%);
            overflow-x: hidden;
        }

        /* ========== TOP HEADER ========== */
        .top-header {
            background: linear-gradient(135deg, #060241, #050347, #021853);
            color: #fef9c3;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            font-size: 12px;
            gap: 12px;
            border-bottom: 2px solid #f59e0b;
        }

        .web-text {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: center;
        }

        .web-text p, .web-text a {
            color: #fef9c3;
            text-decoration: none;
            font-size: 11px;
        }

        .highlight-link {
            color: #fcd34d;
            font-weight: 600;
            transition: all 0.3s;
        }

        .highlight-link:hover {
            color: #f59e0b;
            transform: translateX(3px);
        }

        .right-text {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
        }

        .right-text .link {
            color: #fcd34d;
            text-decoration: none;
            font-size: 11px;
            transition: all 0.3s;
            padding: 3px 8px;
            border-radius: 20px;
        }

        .right-text .link:hover {
            color: #fff;
            background: rgba(245,158,11,0.3);
            transform: translateY(-2px);
        }

        /* ========== MAIN NAVBAR ========== */
        .main-header {
            background: rgba(255, 255, 255, 0.98);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            position: sticky;
            top: 0;
            z-index: 1000;
            position: relative;
        }

        .navbar-line {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #f59e0b, #ec4899, #8b5cf6, #06b6d4, #f59e0b);
            background-size: 200% 100%;
            animation: lineMove 3s ease infinite;
            z-index: 10;
        }

        @keyframes lineMove {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .nav {
            max-width: 1320px;
            margin: 0 auto;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 20px;
        }

        .logo {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo img {
            height: 65px;
            width: auto;
            max-width: 220px;
            object-fit: contain;
            transition: all 0.3s ease;
            border-radius: 8px;
        }

        @media (max-width: 768px) {
            .logo img { height: 50px; max-width: 180px; }
        }

        .menu {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .upperNav {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 8px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .nav-button {
            background: linear-gradient(135deg, #f59e0b, #ec4899, #8b5cf6);
            border: none;
            color: white;
            padding: 8px 28px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(245,158,11,0.35);
        }

        .nav-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(236,72,153,0.45);
        }

        .btn-box { display: flex; gap: 12px; }

        .toggle-btn {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            padding: 8px 22px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            color: white;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .toggle-btn:last-child {
            background: linear-gradient(135deg, #11998e, #38ef7d);
        }

        .toggle-btn:hover { transform: translateY(-2px); }

        .lowerNav {
            display: flex;
            list-style: none;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .menu-link {
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            padding: 8px 18px;
            border-radius: 40px;
            color: #1f2937;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            position: relative;
            z-index: 1;
        }

        .menu-link::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 0%;
            height: 100%;
            background: linear-gradient(120deg, #fef3c7, #fde68a);
            border-radius: 40px;
            transition: 0.3s;
            z-index: -1;
        }

        .menu-link:hover::before { width: 100%; }
        .menu-link:hover { color: #d97706; transform: translateY(-2px); }

        .hamburger {
            display: none;
            flex-direction: column;
            cursor: pointer;
            gap: 5px;
            padding: 10px;
            background: rgba(245,158,11,0.1);
            border-radius: 12px;
        }

        .hamburger span {
            width: 28px;
            height: 3px;
            background: linear-gradient(90deg, #f59e0b, #ec4899);
            border-radius: 5px;
        }

        @media (max-width: 992px) {
            .menu { display: none; }
            .hamburger { display: flex; }
            .top-header { flex-direction: column; text-align: center; }
        }

        /* Mobile Menu */
        .mobile-menu-overlay {
            position: fixed;
            top: 0;
            right: -100%;
            width: 85%;
            max-width: 350px;
            height: 100vh;
            background: white;
            z-index: 2000;
            transition: right 0.3s;
            padding: 80px 25px 30px;
            overflow-y: auto;
        }
        .mobile-menu-overlay.active { right: 0; }
        .close-menu {
            position: absolute;
            top: 20px;
            right: 20px;
            font-size: 28px;
            cursor: pointer;
            color: #f59e0b;
        }
        .mobile-nav-list { list-style: none; }
        .mobile-nav-list li { margin-bottom: 15px; }
        .mobile-nav-list li a {
            text-decoration: none;
            font-size: 16px;
            font-weight: 600;
            color: #1f2937;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 15px;
            border-radius: 12px;
        }
        .screen-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1999;
            display: none;
        }
        .screen-overlay.active { display: block; }

        /* ========== NOTICE BOARD PAGE ========== */
        .page-header {
            background: linear-gradient(135deg, #1e1b4b, #2d1b4e, #4c1d95);
            padding: 60px 20px;
            text-align: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(245,158,11,0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .page-header h1 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 15px;
            position: relative;
            z-index: 1;
        }

        .page-header h1 i {
            color: #f59e0b;
            margin-right: 10px;
        }

        .page-header p {
            font-size: 1rem;
            max-width: 600px;
            margin: 0 auto;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 60px 20px;
        }

        /* Filter Section */
        .filter-section {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            margin-bottom: 40px;
            background: white;
            padding: 20px 25px;
            border-radius: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .filter-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .filter-btn {
            background: #f3f4f6;
            border: none;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            color: #4b5563;
        }

        .filter-btn.active {
            background: linear-gradient(135deg, #f59e0b, #ec4899);
            color: white;
            box-shadow: 0 4px 10px rgba(245,158,11,0.3);
        }

        .filter-btn:hover:not(.active) {
            background: #e5e7eb;
            transform: translateY(-2px);
        }

        .search-box {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #f3f4f6;
            padding: 8px 20px;
            border-radius: 50px;
        }

        .search-box input {
            border: none;
            background: transparent;
            padding: 8px 0;
            font-size: 0.85rem;
            outline: none;
            width: 200px;
            font-family: 'Poppins', sans-serif;
        }

        .search-box i {
            color: #f59e0b;
            cursor: pointer;
        }

        /* Notice Grid */
        .notice-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 25px;
            margin-bottom: 50px;
        }

        .notice-card {
            background: white;
            border-radius: 24px;
            padding: 25px;
            transition: all 0.4s;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            cursor: pointer;
            position: relative;
            overflow: hidden;
            border-left: 5px solid #f59e0b;
        }

        .notice-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.12);
        }

        .notice-badge {
            position: absolute;
            top: 20px;
            right: 20px;
            padding: 5px 12px;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 700;
        }

        .notice-badge.important { background: #fee2e2; color: #dc2626; }
        .notice-badge.academic { background: #dbeafe; color: #2563eb; }
        .notice-badge.exam { background: #fef3c7; color: #d97706; }
        .notice-badge.event { background: #dcfce7; color: #16a34a; }
        .notice-badge.holiday { background: #fce7f3; color: #db2777; }

        .notice-date {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.75rem;
            color: #6b7280;
            margin-bottom: 15px;
        }

        .notice-date i {
            color: #f59e0b;
        }

        .notice-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 12px;
            line-height: 1.4;
        }

        .notice-desc {
            color: #6b7280;
            font-size: 0.85rem;
            line-height: 1.6;
            margin-bottom: 15px;
        }

        .notice-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #f0f0f0;
        }

        .notice-link {
            color: #f59e0b;
            font-size: 0.8rem;
            font-weight: 600;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .notice-link:hover {
            gap: 8px;
        }

        .download-icon {
            color: #6b7280;
            font-size: 0.8rem;
        }

        /* No Results */
        .no-results {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 30px;
        }

        .no-results i {
            font-size: 60px;
            color: #f59e0b;
            margin-bottom: 20px;
        }

        .no-results h3 {
            font-size: 1.3rem;
            color: #1f2937;
            margin-bottom: 10px;
        }

        /* Notice Stats */
        .notice-stats {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 30px;
            margin-top: 40px;
            padding: 30px;
            background: linear-gradient(135deg, #fff7ed, #ffedd5);
            border-radius: 30px;
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-size: 2rem;
            font-weight: 800;
            color: #ec4899;
        }

        .stat-label {
            font-size: 0.8rem;
            color: #4b5563;
        }

        /* Footer */
        .footer {
            background: linear-gradient(135deg, #0f172a, #1e1b4b);
            color: #e0e7ff;
            padding: 40px 20px 20px;
        }

        .footer-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
        }

        .footer-col h4 {
            color: #f59e0b;
            margin-bottom: 15px;
        }

        .footer-col a, .footer-col p {
            display: block;
            color: #cbd5e6;
            text-decoration: none;
            font-size: 0.8rem;
            margin-bottom: 8px;
            transition: all 0.3s;
        }

        .footer-col a:hover { color: #f59e0b; transform: translateX(5px); }

        .footer-bottom {
            text-align: center;
            padding-top: 30px;
            margin-top: 30px;
            border-top: 1px solid rgba(245,158,11,0.2);
            font-size: 0.7rem;
        }

        @media (max-width: 768px) {
            .page-header h1 { font-size: 1.8rem; }
            .filter-section { flex-direction: column; align-items: stretch; }
            .search-box input { width: 100%; }
            .notice-grid { grid-template-columns: 1fr; }
            .container { padding: 40px 15px; }
        }
    </style>
</head>
<body>
<%-include('partials/header')%>
<!-- TOP HEADER -->
