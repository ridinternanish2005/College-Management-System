<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>MSD Public School | Join Our Faculty - Full Screen Application</title>
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    
<link rel="stylesheet" href="/svic_college/css/teacher.css">
</head>
<body>
<%- include('partials/header') %>
<!-- Background Particles -->
<div class="bg-particles" id="particles"></div>

<section class="apply-section" id="teacher-apply">
    <div class="apply-container">
       
        <div class="apply-form">
            <div id="formMessage" class="alert-message"></div>
            
            <form id="teacherApplicationForm" method="POST" enctype="multipart/form-data">
                <div class="form-row">
                    <div class="form-group" id="group-fullname">
                        <label><i class="fas fa-user-graduate"></i> Full Name <span class="required">*</span></label>
                        <input type="text" name="full_name" id="full_name" required placeholder="Dr. Amit Sharma" autocomplete="name">
                    </div>
                    <div class="form-group" id="group-email">
                        <label><i class="fas fa-envelope"></i> Email Address <span class="required">*</span></label>
                        <input type="email" name="email" id="email" required placeholder="teacher@msd.edu" autocomplete="email">
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group" id="group-mobile">
                        <label><i class="fas fa-phone-alt"></i> Mobile Number <span class="required">*</span></label>
                        <input type="tel" name="mobile" id="mobile" pattern="[0-9]{10}" required placeholder="9876543210" maxlength="10">
                    </div>
                    <div class="form-group" id="group-qualification">
                        <label><i class="fas fa-graduation-cap"></i> Highest Qualification <span class="required">*</span></label>
                        <input type="text" name="qualification" id="qualification" required placeholder="M.Sc, B.Ed, Ph.D">
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group" id="group-experience">
                        <label><i class="fas fa-briefcase"></i> Years of Experience <span class="required">*</span></label>
                        <input type="number" name="experience" id="experience" min="0" max="50" step="1" required placeholder="0">
                    </div>
                    <div class="form-group" id="group-subject">
                        <label><i class="fas fa-book-open"></i> Subject Expertise <span class="required">*</span></label>
                        <select name="subject" id="subject" required>
                            <option value="">-- Select Subject --</option>
                            <option>📐 Mathematics</option>
                            <option>⚛️ Physics</option>
                            <option>🧪 Chemistry</option>
                            <option>🔬 Biology</option>
                            <option>📖 English</option>
                            <option>📚 Hindi</option>
                            <option>🕉️ Sanskrit</option>
                            <option>🌍 Social Studies</option>
                            <option>💻 Computer Science</option>
                            <option>🏃 Physical Education</option>
                            <option>📊 Commerce</option>
                            <option>💰 Economics</option>
                            <option>⚖️ Political Science</option>
                            <option>🏛️ History</option>
                            <option>🗺️ Geography</option>
                        </select>
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-chalkboard"></i> Preferred Class to Teach</label>
                        <input type="text" name="preferred_class" id="preferred_class" placeholder="e.g., 11th-12th Science">
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-building"></i> Current/Last Organization</label>
                        <input type="text" name="last_organization" id="last_organization" placeholder="Previous institution">
                    </div>
                </div>
                
                <div class="form-group">
                    <label><i class="fas fa-map-marker-alt"></i> Complete Address</label>
                    <textarea name="address" id="address" rows="3" placeholder="Enter your full address with city & pin code"></textarea>
                    <div class="char-counter" id="addressCounter">0/300 characters</div>
                </div>
                
                <div class="form-group">
                    <label><i class="fas fa-file-pdf"></i> Upload Resume/CV <span class="required">*</span></label>
                    <div class="file-upload-wrapper">
                        <input type="file" name="resume" id="resume" accept=".pdf" required>
                    </div>
                    <small><i class="fas fa-info-circle"></i> PDF only, Max 5MB. Include detailed CV.</small>
                </div>
                
                <button type="submit" class="submit-btn" id="submitBtn">
                    <i class="fas fa-paper-plane"></i> Submit Application
                    <i class="fas fa-arrow-right"></i>
                </button>
            </form>
        </div>
    </div>
</section>
<script src="/svic_college/js/teacher.js"></script>

 <%- include('partials/footer') %>
</body>
</html>