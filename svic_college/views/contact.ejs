<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Contact Us | SVIC Inter College</title>
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #fef9f0 0%, #fff4e8 100%);
            overflow-x: hidden;
        }

        /* ========== TOP HEADER ========== */
        .top-header {
            background: linear-gradient(135deg, #060241, #050347, #021853);
            color: #fef9c3;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            font-size: 12px;
            gap: 12px;
            border-bottom: 2px solid #f59e0b;
        }

        .web-text {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: center;
        }

        .web-text p, .web-text a {
            color: #fef9c3;
            text-decoration: none;
            font-size: 11px;
        }

        .highlight-link {
            color: #fcd34d;
            font-weight: 600;
            transition: all 0.3s;
        }

        .highlight-link:hover {
            color: #f59e0b;
            transform: translateX(3px);
        }

        .right-text {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
        }

        .right-text .link {
            color: #fcd34d;
            text-decoration: none;
            font-size: 11px;
            transition: all 0.3s;
            padding: 3px 8px;
            border-radius: 20px;
        }

        .right-text .link:hover {
            color: #fff;
            background: rgba(245,158,11,0.3);
            transform: translateY(-2px);
        }

        /* ========== MAIN NAVBAR ========== */
        .main-header {
            background: rgba(255, 255, 255, 0.98);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            position: sticky;
            top: 0;
            z-index: 1000;
            position: relative;
        }

        .navbar-line {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #f59e0b, #ec4899, #8b5cf6, #06b6d4, #f59e0b);
            background-size: 200% 100%;
            animation: lineMove 3s ease infinite;
            z-index: 10;
        }

        @keyframes lineMove {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .nav {
            max-width: 1320px;
            margin: 0 auto;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 20px;
        }

        .logo {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo img {
            height: 65px;
            width: auto;
            max-width: 220px;
            object-fit: contain;
            transition: all 0.3s ease;
            border-radius: 8px;
        }

        @media (max-width: 768px) {
            .logo img { height: 50px; max-width: 180px; }
        }

        .menu {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .upperNav {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 8px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .nav-button {
            background: linear-gradient(135deg, #f59e0b, #ec4899, #8b5cf6);
            border: none;
            color: white;
            padding: 8px 28px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(245,158,11,0.35);
        }

        .nav-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(236,72,153,0.45);
        }

        .btn-box { display: flex; gap: 12px; }

        .toggle-btn {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            padding: 8px 22px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            color: white;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .toggle-btn:last-child {
            background: linear-gradient(135deg, #11998e, #38ef7d);
        }

        .toggle-btn:hover { transform: translateY(-2px); }

        .lowerNav {
            display: flex;
            list-style: none;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .menu-link {
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            padding: 8px 18px;
            border-radius: 40px;
            color: #1f2937;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            position: relative;
            z-index: 1;
        }

        .menu-link::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 0%;
            height: 100%;
            background: linear-gradient(120deg, #fef3c7, #fde68a);
            border-radius: 40px;
            transition: 0.3s;
            z-index: -1;
        }

        .menu-link:hover::before { width: 100%; }
        .menu-link:hover { color: #d97706; transform: translateY(-2px); }

        .hamburger {
            display: none;
            flex-direction: column;
            cursor: pointer;
            gap: 5px;
            padding: 10px;
            background: rgba(245,158,11,0.1);
            border-radius: 12px;
        }

        .hamburger span {
            width: 28px;
            height: 3px;
            background: linear-gradient(90deg, #f59e0b, #ec4899);
            border-radius: 5px;
        }

        @media (max-width: 992px) {
            .menu { display: none; }
            .hamburger { display: flex; }
            .top-header { flex-direction: column; text-align: center; }
        }

        /* Mobile Menu */
        .mobile-menu-overlay {
            position: fixed;
            top: 0;
            right: -100%;
            width: 85%;
            max-width: 350px;
            height: 100vh;
            background: white;
            z-index: 2000;
            transition: right 0.3s;
            padding: 80px 25px 30px;
            overflow-y: auto;
        }
        .mobile-menu-overlay.active { right: 0; }
        .close-menu {
            position: absolute;
            top: 20px;
            right: 20px;
            font-size: 28px;
            cursor: pointer;
            color: #f59e0b;
        }
        .mobile-nav-list { list-style: none; }
        .mobile-nav-list li { margin-bottom: 15px; }
        .mobile-nav-list li a {
            text-decoration: none;
            font-size: 16px;
            font-weight: 600;
            color: #1f2937;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 15px;
            border-radius: 12px;
        }
        .screen-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1999;
            display: none;
        }
        .screen-overlay.active { display: block; }

        /* ========== CONTACT US PAGE ========== */
        .page-header {
            background: linear-gradient(135deg, #1e1b4b, #2d1b4e, #4c1d95);
            padding: 60px 20px;
            text-align: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(245,158,11,0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .page-header h1 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 15px;
            position: relative;
            z-index: 1;
        }

        .page-header h1 i {
            color: #f59e0b;
            margin-right: 10px;
        }

        .page-header p {
            font-size: 1rem;
            max-width: 600px;
            margin: 0 auto;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 60px 20px;
        }

        /* Contact Grid */
        .contact-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 60px;
        }

        .contact-card {
            background: white;
            border-radius: 25px;
            padding: 35px 25px;
            text-align: center;
            transition: all 0.4s;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            cursor: pointer;
        }

        .contact-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.12);
        }

        .contact-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #fef3c7, #fde68a);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .contact-icon i {
            font-size: 32px;
            color: #f59e0b;
        }

        .contact-card h3 {
            font-size: 1.3rem;
            margin-bottom: 15px;
            color: #1f2937;
        }

        .contact-card p {
            color: #6b7280;
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .contact-card .contact-detail {
            font-weight: 600;
            color: #ec4899;
            margin-top: 10px;
        }

        /* Map and Form Section */
        .map-form-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 30px;
            margin-bottom: 60px;
        }

        .map-container {
            background: white;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        .map-container iframe {
            width: 100%;
            height: 400px;
            border: none;
        }

        .form-container {
            background: white;
            border-radius: 25px;
            padding: 35px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        .form-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 25px;
            color: #1f2937;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .form-title i {
            color: #f59e0b;
        }

        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .input-group label {
            font-weight: 600;
            font-size: 0.85rem;
            color: #4b5563;
        }

        .input-group label .required {
            color: #ec4899;
        }

        .input-group input,
        .input-group select,
        .input-group textarea {
            padding: 12px 15px;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            font-family: 'Poppins', sans-serif;
            font-size: 0.9rem;
            transition: all 0.3s;
            outline: none;
        }

        .input-group input:focus,
        .input-group select:focus,
        .input-group textarea:focus {
            border-color: #f59e0b;
            box-shadow: 0 0 0 3px rgba(245,158,11,0.1);
        }

        .submit-btn {
            background: linear-gradient(135deg, #f59e0b, #ec4899);
            border: none;
            color: white;
            padding: 14px 30px;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
        }

        .submit-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(245,158,11,0.4);
        }

        /* Department Contacts */
        .dept-section {
            background: linear-gradient(135deg, #fff7ed, #ffedd5);
            border-radius: 30px;
            padding: 40px;
            margin-bottom: 60px;
        }

        .section-title {
            text-align: center;
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 35px;
            background: linear-gradient(135deg, #f59e0b, #ec4899);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .dept-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
        }

        .dept-card {
            background: white;
            border-radius: 20px;
            padding: 25px;
            text-align: center;
            transition: all 0.3s;
            cursor: pointer;
        }

        .dept-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .dept-card i {
            font-size: 40px;
            color: #f59e0b;
            margin-bottom: 15px;
        }

        .dept-card h4 {
            font-size: 1.1rem;
            margin-bottom: 8px;
        }

        .dept-card p {
            font-size: 0.8rem;
            color: #6b7280;
        }

        .dept-card .phone {
            font-weight: 600;
            color: #ec4899;
            margin-top: 10px;
        }

        /* Social Media Section */
        .social-section {
            text-align: center;
            padding: 40px;
            background: white;
            border-radius: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        .social-section h3 {
            font-size: 1.3rem;
            margin-bottom: 20px;
            color: #1f2937;
        }

        .social-icons {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .social-icon {
            width: 55px;
            height: 55px;
            background: linear-gradient(135deg, #fef3c7, #fde68a);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            cursor: pointer;
            text-decoration: none;
        }

        .social-icon i {
            font-size: 24px;
            color: #f59e0b;
        }

        .social-icon:hover {
            transform: translateY(-5px);
            background: linear-gradient(135deg, #f59e0b, #ec4899);
        }

        .social-icon:hover i {
            color: white;
        }

        /* Footer */
        .footer {
            background: linear-gradient(135deg, #0f172a, #1e1b4b);
            color: #e0e7ff;
            padding: 40px 20px 20px;
        }

        .footer-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
        }

        .footer-col h4 {
            color: #f59e0b;
            margin-bottom: 15px;
        }

        .footer-col a, .footer-col p {
            display: block;
            color: #cbd5e6;
            text-decoration: none;
            font-size: 0.8rem;
            margin-bottom: 8px;
            transition: all 0.3s;
        }

        .footer-col a:hover { color: #f59e0b; transform: translateX(5px); }

        .footer-bottom {
            text-align: center;
            padding-top: 30px;
            margin-top: 30px;
            border-top: 1px solid rgba(245,158,11,0.2);
            font-size: 0.7rem;
        }

        @media (max-width: 768px) {
            .page-header h1 { font-size: 1.8rem; }
            .form-row { grid-template-columns: 1fr; }
            .map-form-section { grid-template-columns: 1fr; }
            .container { padding: 40px 15px; }
            .dept-section { padding: 25px; }
        }
    </style>
</head>
<body>
    <%-include('partials/header')%>

<!-- TOP HEADER -->
<div class="top-header">
    <div class="web-text">
        <p>📚 UP Board Affiliated</p>
        <p>📞 Helpline: +91-9876543210</p>
