        <a class="link" href="#">🎓 ESTD: 1995</a>
        <a class="link" href="#">⭐ Best College Award</a>
    </div>
</div>

<!-- MAIN NAVBAR -->
<div class="main-header">
    <div class="navbar-line"></div>
    <div class="nav">
        <div class="logo">
            <img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 200'%3E%3Ccircle cx='100' cy='100' r='95' fill='%23fff8ed' stroke='%23f59e0b' stroke-width='5'/%3E%3Ctext x='100' y='115' text-anchor='middle' font-size='28' fill='%23f59e0b' font-weight='800'%3ESVIC%3C/text%3E%3Ctext x='100' y='145' text-anchor='middle' font-size='12' fill='%238b5cf6'%3EINTER COLLEGE%3C/text%3E%3C/svg%3E" alt="SVIC Inter College Logo">
        </div>
        <div class="menu">
            <div class="upperNav">
                <button class="nav-button" onclick="showToast('🎓 Apply Now - Admission Open 2025-26')"><i class="fas fa-pen-alt"></i> Apply Now</button>
                <div class="btn-box">
                    <button class="toggle-btn" onclick="showToast('🔐 Student Login Portal Coming Soon')"><i class="fas fa-sign-in-alt"></i> Login</button>
                    <button class="toggle-btn" onclick="showToast('📝 Register for Admission 2025-26')"><i class="fas fa-user-plus"></i> Register</button>
                </div>
            </div>
            <ul class="lowerNav">
                <li><a class="menu-link" href="#"><i class="fas fa-home"></i> Home</a></li>
                <li><a class="menu-link" href="#"><i class="fas fa-info-circle"></i> About</a></li>
                <li><a class="menu-link" href="#"><i class="fas fa-door-open"></i> Admission</a></li>
                <li><a class="menu-link" href="#"><i class="fas fa-book-open"></i> Courses</a></li>
                <li><a class="menu-link" href="#"><i class="fas fa-bell"></i> Notice</a></li>
                <li><a class="menu-link" href="#" style="color:#f59e0b;"><i class="fas fa-headset"></i> Contact</a></li>
            </ul>
        </div>
        <div class="hamburger" onclick="openMobileMenu()">
            <span></span><span></span><span></span>
        </div>
    </div>
</div>

<!-- Mobile Menu -->
<div class="mobile-menu-overlay" id="mobileMenu">
    <div class="close-menu" onclick="closeMobileMenu()"><i class="fas fa-times"></i></div>
    <ul class="mobile-nav-list">
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-home"></i> Home</a></li>
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-info-circle"></i> About</a></li>
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-door-open"></i> Admission</a></li>
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-book-open"></i> Courses</a></li>
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-bell"></i> Notice</a></li>
        <li><a href="#" onclick="closeMobileMenu()"><i class="fas fa-headset"></i> Contact</a></li>
        <li><button class="nav-button" style="width:100%;" onclick="showToast('Apply Now'); closeMobileMenu();"><i class="fas fa-pen-alt"></i> Apply Now</button></li>
    </ul>
</div>
<div class="screen-overlay" id="screenOverlay" onclick="closeMobileMenu()"></div>

<!-- PAGE HEADER -->
<div class="page-header">
    <h1><i class="fas fa-headset"></i> Contact Us</h1>
    <p>Get in touch with us for any queries, feedback, or assistance. We're here to help you!</p>
</div>

<div class="container">
    <!-- Contact Cards -->
    <div class="contact-grid">
        <div class="contact-card" onclick="showToast('📍 Visit our campus for admission inquiries')">
            <div class="contact-icon"><i class="fas fa-map-marker-alt"></i></div>
            <h3>Visit Us</h3>
            <p>SVIC Campus, Knowledge Park<br>Greater Noida, Uttar Pradesh - 201310</p>
            <p class="contact-detail"><i class="fas fa-clock"></i> Mon-Sat: 9:00 AM - 5:00 PM</p>
        </div>
        <div class="contact-card" onclick="showToast('📞 Call us for any assistance')">
            <div class="contact-icon"><i class="fas fa-phone-alt"></i></div>
            <h3>Call Us</h3>
            <p>Admission Helpline: +91-9876543210</p>
            <p>General Inquiry: +91-9876543211</p>
            <p class="contact-detail"><i class="fas fa-fax"></i> Fax: 0120-1234567</p>
        </div>
        <div class="contact-card" onclick="showToast('✉️ Email us for detailed queries')">
            <div class="contact-icon"><i class="fas fa-envelope"></i></div>
            <h3>Email Us</h3>
            <p>General: info@svic.edu.in</p>
            <p>Admission: admission@svic.edu.in</p>
            <p>Support: support@svic.edu.in</p>
        </div>
    </div>

    <!-- Map and Contact Form -->
    <div class="map-form-section">
        <div class="map-container">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3504.998761248677!2d77.5368409!3d28.5354945!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x390cebf5b3fb0d0b%3A0x2c3b8e2b5c7a3c4f!2sKnowledge%20Park%2C%20Greater%20Noida!5e0!3m2!1sen!2sin!4v1700000000000!5m2!1sen!2sin" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
        <div class="form-container">
            <div class="form-title">
                <i class="fas fa-paper-plane"></i>
