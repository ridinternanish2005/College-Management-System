<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>SVIC College | Modern Colorful Interactive Footer</title>
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', system-ui, -apple-system, sans-serif;
            background: linear-gradient(135deg, #f0f4f8 0%, #e8eef5 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Dummy content to show footer at bottom */
        .dummy-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 4rem 2rem;
            text-align: center;
        }

        .dummy-content h2 {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #1e3a5f, #f4a261);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 1rem;
        }

        .dummy-content p {
            color: #4a627a;
            font-size: 1.1rem;
        }

        /* ========== MODERN COLORFUL INTERACTIVE FOOTER ========== */
        .footer {
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #2d1b4e 100%);
            color: #e0e7ff;
            width: 100%;
            margin-top: auto;
            position: relative;
            overflow: hidden;
        }

        /* Animated gradient overlay */
        .footer::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #f59e0b, #ec4899, #8b5cf6, #06b6d4, #f59e0b);
            background-size: 200% 100%;
            animation: gradientMove 3s ease infinite;
        }

        @keyframes gradientMove {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .footer-container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 3rem 2rem 1.5rem;
            position: relative;
            z-index: 2;
        }

        /* Main footer grid */
        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 2rem;
            margin-bottom: 2.5rem;
        }

        .footer-col {
            animation: fadeInUp 0.6s ease backwards;
        }

        .footer-col:nth-child(1) { animation-delay: 0.1s; }
        .footer-col:nth-child(2) { animation-delay: 0.2s; }
        .footer-col:nth-child(3) { animation-delay: 0.3s; }
        .footer-col:nth-child(4) { animation-delay: 0.4s; }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .footer-col h4 {
            color: #f59e0b;
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 1.2rem;
            position: relative;
            display: inline-block;
            letter-spacing: 0.5px;
        }

        .footer-col h4::after {
            content: '';
            position: absolute;
            bottom: -6px;
            left: 0;
            width: 40px;
            height: 3px;
            background: linear-gradient(90deg, #f59e0b, #ec4899);
            border-radius: 3px;
            transition: width 0.3s ease;
        }

        .footer-col:hover h4::after {
            width: 70px;
        }

        .footer-col p, .footer-col a {
            font-size: 0.85rem;
            line-height: 1.7;
            color: #cbd5e6;
            text-decoration: none;
            display: block;
            margin-bottom: 0.6rem;
            transition: all 0.3s ease;
        }

        .footer-col a {
            position: relative;
            padding-left: 0;
        }

        .footer-col a:hover {
            color: #f59e0b;
            transform: translateX(8px);
        }

        .footer-col a i {
            width: 22px;
            margin-right: 6px;
            color: #f59e0b;
            transition: transform 0.3s ease;
        }

        .footer-col a:hover i {
            transform: translateX(4px);
        }

        /* College Info Description */
        .footer-col:first-child p {
            margin-bottom: 1rem;
            line-height: 1.6;
        }

        /* Social Icons - Modern & Interactive */
        .social-icons {
            display: flex;
            gap: 0.8rem;
            margin-top: 1rem;
            flex-wrap: wrap;
        }

        .social-icons a {
            background: rgba(255, 255, 255, 0.08);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-size: 1.1rem;
            color: #cbd5e6;
            text-decoration: none;
            margin: 0;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(245, 158, 11, 0.2);
        }

        .social-icons a:hover {
            transform: translateY(-5px) scale(1.1);
            color: white;
        }

        .social-icons a:nth-child(1):hover { background: #1877f2; border-color: #1877f2; }
        .social-icons a:nth-child(2):hover { background: #1da1f2; border-color: #1da1f2; }
        .social-icons a:nth-child(3):hover { background: #e4405f; border-color: #e4405f; }
        .social-icons a:nth-child(4):hover { background: #0077b5; border-color: #0077b5; }

        /* Contact Items with Icons */
        .contact-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 0.8rem;
        }

        .contact-item i {
            color: #f59e0b;
            font-size: 1rem;
            margin-top: 3px;
            min-width: 20px;
            transition: transform 0.3s ease;
        }

        .contact-item:hover i {
            transform: scale(1.2);
            color: #ec4899;
        }

        .contact-item p {
            margin: 0;
            flex: 1;
        }

        /* Footer Bottom */
        .footer-bottom {
            border-top: 1px solid rgba(245, 158, 11, 0.2);
            padding-top: 1.5rem;
            text-align: center;
            font-size: 0.75rem;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
        }

        .copyright {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .copyright i {
            color: #f59e0b;
            animation: heartbeat 1.5s ease infinite;
        }

        @keyframes heartbeat {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.15); }
        }

        .footer-links {
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .footer-links a {
            color: #9bb3cc;
            text-decoration: none;
            font-size: 0.75rem;
            transition: all 0.3s;
            position: relative;
        }

        .footer-links a::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, #f59e0b, #ec4899);
            transition: width 0.3s ease;
        }

        .footer-links a:hover {
            color: #f59e0b;
        }

        .footer-links a:hover::after {
            width: 100%;
        }

        /* Newsletter Section (Bonus Interactive) */
        .newsletter-section {
            margin-top: 1rem;
        }

        .newsletter-title {
            font-size: 0.9rem;
            font-weight: 600;
            color: #f59e0b;
            margin-bottom: 0.8rem;
        }

        .newsletter-form {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .newsletter-input {
            flex: 1;
            padding: 10px 15px;
            border: 1px solid rgba(245, 158, 11, 0.3);
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50px;
            color: white;
            font-size: 0.8rem;
            font-family: 'Poppins', sans-serif;
            transition: all 0.3s;
        }

        .newsletter-input:focus {
            outline: none;
            border-color: #f59e0b;
            background: rgba(255, 255, 255, 0.15);
            box-shadow: 0 0 10px rgba(245, 158, 11, 0.3);
        }

        .newsletter-input::placeholder {
            color: #9bb3cc;
        }

        .newsletter-btn {
            background: linear-gradient(135deg, #f59e0b, #ec4899);
            border: none;
            padding: 10px 20px;
            border-radius: 50px;
            color: white;
            font-weight: 600;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .newsletter-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(245, 158, 11, 0.4);
        }

        .newsletter-btn:active {
            transform: translateY(0);
        }

        /* Back to Top Button */
        .back-to-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #f59e0b, #ec4899);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            opacity: 0;
            visibility: hidden;
            z-index: 1000;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            border: none;
            font-size: 1.2rem;
        }

        .back-to-top.show {
            opacity: 1;
            visibility: visible;
        }

        .back-to-top:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(245, 158, 11, 0.5);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .footer-container {
                padding: 2rem 1.5rem 1.2rem;
            }
            .footer-grid {
                gap: 1.8rem;
            }
            .footer-bottom {
                flex-direction: column;
                text-align: center;
                gap: 0.8rem;
            }
            .footer-links {
                justify-content: center;
            }
            .newsletter-form {
                flex-direction: column;
            }
            .newsletter-btn {
                justify-content: center;
            }
        }

        @media (max-width: 480px) {
            .footer-col h4 {
                font-size: 1rem;
            }
            .social-icons a {
                width: 36px;
                height: 36px;
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
  
    <!-- ========== MODERN COLORFUL INTERACTIVE FOOTER ========== -->
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-grid">
                <!-- College Info with Social Media -->
                <div class="footer-col">
                    <h4>SVIC College</h4>
                    <p>Empowering education with innovation, integrity, and excellence. Shaping future leaders through quality academics & research.</p>
                    <div class="social-icons">
                        <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                        <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
                
                <!-- Quick Links with Icons -->
                <div class="footer-col">
                    <h4>Quick Links</h4>
                    <a href="#"><i class="fas fa-chevron-right"></i> About Us</a>
                    <a href="#"><i class="fas fa-chevron-right"></i> Admissions</a>
                    <a href="#"><i class="fas fa-chevron-right"></i> Academics</a>
                    <a href="#"><i class="fas fa-chevron-right"></i> Research</a>
                    <a href="#"><i class="fas fa-chevron-right"></i> Placements</a>
                    <a href="#"><i class="fas fa-chevron-right"></i> Campus Life</a>
                </div>
                
                <!-- Resources -->
                <div class="footer-col">
                    <h4>Resources</h4>
                    <a href="#"><i class="fas fa-chevron-right"></i> Student Portal</a>
                    <a href="#"><i class="fas fa-chevron-right"></i> Faculty Portal</a>
                    <a href="#"><i class="fas fa-chevron-right"></i> Digital Library</a>
                    <a href="#"><i class="fas fa-chevron-right"></i> Exam Schedule</a>
                    <a href="#"><i class="fas fa-chevron-right"></i> Fee Structure</a>
                    <a href="#"><i class="fas fa-chevron-right"></i> Scholarships</a>
                </div>
                
                <!-- Contact & Newsletter -->
                <div class="footer-col">
                    <h4>Contact Us</h4>
                    <div class="contact-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <p>SVIC Campus, Knowledge Park, Greater Noida, UP - 201310</p>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-phone-alt"></i>
                        <p>+91-120-4567890</p>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-envelope"></i>
                        <p>info@svic.edu.in</p>
                    </div>
                    
                    <!-- Newsletter Subscription -->
                    <div class="newsletter-section">
                        <div class="newsletter-title">
                            <i class="fas fa-paper-plane"></i> Subscribe to Newsletter
                        </div>
                        <div class="newsletter-form">
                            <input type="email" class="newsletter-input" placeholder="Your email address" id="newsletterEmail">
                            <button class="newsletter-btn" onclick="subscribeNewsletter()">
                                <i class="fas fa-bell"></i> Subscribe
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Footer Bottom -->
            <div class="footer-bottom">
                <div class="copyright">
                    <i class="fas fa-heart"></i>
                    <span>© 2025 SVIC College. All rights reserved.</span>
                </div>
                <div class="footer-links">
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Use</a>
                    <a href="#">Cookie Policy</a>
                    <a href="#">Support</a>
                    <a href="#">Sitemap</a>
                </div>
            </div>
        </div>
    </footer>
    
    <!-- Back to Top Button -->
    <div class="back-to-top" id="backToTop" onclick="scrollToTop()">
        <i class="fas fa-arrow-up"></i>
    </div>

    <script>
        // Newsletter Subscription Function
        function subscribeNewsletter() {
            const emailInput = document.getElementById('newsletterEmail');
            const email = emailInput.value.trim();
            if (email === '') {
                showToast('⚠️ Please enter your email address!', '#f59e0b');
                emailInput.style.borderColor = '#f59e0b';
                setTimeout(() => {
                    emailInput.style.borderColor = 'rgba(245, 158, 11, 0.3)';
                }, 1500);
                return;
            }
            if (!email.includes('@') || !email.includes('.')) {
                showToast('❌ Please enter a valid email address!', '#ec4899');
                return;
            }
            showToast('✅ Subscribed successfully! 🎉 Thank you.', '#10b981');
            emailInput.value = '';
        }

        // Toast Notification
        function showToast(message, color) {
            // Create toast element
            const toast = document.createElement('div');
            toast.innerHTML = `
                <div style="
                    position: fixed;
                    bottom: 30px;
                    left: 50%;
                    transform: translateX(-50%);
                    background: ${color};
                    color: white;
                    padding: 12px 24px;
                    border-radius: 50px;
                    font-size: 14px;
                    font-weight: 500;
                    z-index: 10000;
                    box-shadow: 0 5px 20px rgba(0,0,0,0.2);
                    animation: slideUp 0.3s ease;
                    font-family: 'Poppins', sans-serif;
                ">
                    ${message}
                </div>
            `;
            document.body.appendChild(toast);
            
            // Add animation style if not exists
            if (!document.querySelector('#toast-animation-style')) {
                const style = document.createElement('style');
                style.id = 'toast-animation-style';
                style.textContent = `
                    @keyframes slideUp {
                        from {
                            opacity: 0;
                            transform: translateX(-50%) translateY(20px);
                        }
                        to {
                            opacity: 1;
                            transform: translateX(-50%) translateY(0);
                        }
                    }
                `;
                document.head.appendChild(style);
            }
            
            setTimeout(() => {
                toast.remove();
            }, 3000);
        }

        // Back to Top Button Functionality
        function scrollToTop() {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        }

        // Show/Hide Back to Top Button based on scroll
        window.addEventListener('scroll', () => {
            const backToTopBtn = document.getElementById('backToTop');
            if (window.scrollY > 300) {
                backToTopBtn.classList.add('show');
            } else {
                backToTopBtn.classList.remove('show');
            }
        });

        // Add hover ripple effect on social links
        const socialLinks = document.querySelectorAll('.social-icons a');
        socialLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const platform = link.getAttribute('aria-label');
                showToast(`🔗 ${platform} - Coming Soon!`, '#f59e0b');
            });
        });

        // Add click handlers for footer links to prevent page reload (demo)
        const allFooterLinks = document.querySelectorAll('.footer-col a:not(.newsletter-btn)');
        allFooterLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                if (link.getAttribute('href') === '#') {
                    e.preventDefault();
                    const text = link.innerText.trim();
                    showToast(`📌 ${text} - Page Coming Soon`, '#8b5cf6');
                }
            });
        });

        // Smooth hover effect on contact items
        console.log('✅ Modern Colorful Interactive Footer Loaded!');
    </script>
</body>
</html>