<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>SVIC Inter College | Home</title>
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #fef9f0 0%, #fff4e8 100%);
            overflow-x: hidden;
        }

        /* ========== TOP HEADER ========== */
        .top-header {
            background: linear-gradient(135deg, #060241, #050347, #021853);
            color: #fef9c3;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            font-size: 12px;
            gap: 12px;
            border-bottom: 2px solid #f59e0b;
        }

        .web-text {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: center;
        }

        .web-text p, .web-text a {
            color: #fef9c3;
            text-decoration: none;
            font-size: 11px;
        }

        .highlight-link {
            color: #fcd34d;
            font-weight: 600;
            transition: all 0.3s;
        }

        .highlight-link:hover {
            color: #f59e0b;
            transform: translateX(3px);
        }

        .right-text {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
        }

        .right-text .link {
            color: #fcd34d;
            text-decoration: none;
            font-size: 11px;
            transition: all 0.3s;
            padding: 3px 8px;
            border-radius: 20px;
        }

        .right-text .link:hover {
            color: #fff;
            background: rgba(245,158,11,0.3);
            transform: translateY(-2px);
        }

        /* ========== MAIN NAVBAR ========== */
        .main-header {
            background: rgba(255, 255, 255, 0.98);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            position: sticky;
            top: 0;
            z-index: 1000;
            position: relative;
        }

        .navbar-line {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #f59e0b, #ec4899, #8b5cf6, #06b6d4, #f59e0b);
            background-size: 200% 100%;
            animation: lineMove 3s ease infinite;
            z-index: 10;
        }

        @keyframes lineMove {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .nav {
            max-width: 1320px;
            margin: 0 auto;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 20px;
        }

        .logo {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo img {
            height: 65px;
            width: auto;
            max-width: 220px;
            object-fit: contain;
            transition: all 0.3s ease;
            border-radius: 8px;
        }

        @media (max-width: 768px) {
            .logo img { height: 50px; max-width: 180px; }
        }

        .menu {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .upperNav {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 8px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .nav-button {
            background: linear-gradient(135deg, #f59e0b, #ec4899, #8b5cf6);
            border: none;
            color: white;
            padding: 8px 28px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(245,158,11,0.35);
        }

        .nav-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(236,72,153,0.45);
        }

        .btn-box { display: flex; gap: 12px; }

        .toggle-btn {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            padding: 8px 22px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            color: white;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .toggle-btn:last-child {
            background: linear-gradient(135deg, #11998e, #38ef7d);
        }

        .toggle-btn:hover { transform: translateY(-2px); }

        .lowerNav {
            display: flex;
            list-style: none;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .menu-link {
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            padding: 8px 18px;
            border-radius: 40px;
            color: #1f2937;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            position: relative;
            z-index: 1;
        }

        .menu-link::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 0%;
            height: 100%;
            background: linear-gradient(120deg, #fef3c7, #fde68a);
            border-radius: 40px;
            transition: 0.3s;
            z-index: -1;
        }

        .menu-link:hover::before { width: 100%; }
        .menu-link:hover { color: #d97706; transform: translateY(-2px); }

        .hamburger {
            display: none;
            flex-direction: column;
            cursor: pointer;
            gap: 5px;
            padding: 10px;
            background: rgba(245,158,11,0.1);
            border-radius: 12px;
        }

        .hamburger span {
            width: 28px;
            height: 3px;
            background: linear-gradient(90deg, #f59e0b, #ec4899);
            border-radius: 5px;
        }

        @media (max-width: 992px) {
            .menu { display: none; }
            .hamburger { display: flex; }
            .top-header { flex-direction: column; text-align: center; }
        }

        /* Mobile Menu */
        .mobile-menu-overlay {
            position: fixed;
            top: 0;
            right: -100%;
            width: 85%;
            max-width: 350px;
            height: 100vh;
            background: white;
            z-index: 2000;
            transition: right 0.3s;
            padding: 80px 25px 30px;
            overflow-y: auto;
        }
        .mobile-menu-overlay.active { right: 0; }
        .close-menu {
            position: absolute;
            top: 20px;
            right: 20px;
            font-size: 28px;
            cursor: pointer;
            color: #f59e0b;
        }
        .mobile-nav-list { list-style: none; }
        .mobile-nav-list li { margin-bottom: 15px; }
        .mobile-nav-list li a {
            text-decoration: none;
            font-size: 16px;
            font-weight: 600;
            color: #1f2937;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 15px;
            border-radius: 12px;
        }
        .screen-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1999;
            display: none;
        }
        .screen-overlay.active { display: block; }

        /* ========== HERO SECTION ========== */
        .hero {
            background: linear-gradient(135deg, #1e1b4b, #2d1b4e, #4c1d95);
            padding: 80px 20px;
            text-align: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(245,158,11,0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .hero-content {
            max-width: 800px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        .hero h1 {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 20px;
        }

        .hero h1 span {
            background: linear-gradient(135deg, #f59e0b, #ec4899);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .hero p {
            font-size: 1.1rem;
            margin-bottom: 30px;
            opacity: 0.9;
        }

        .hero-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary {
            background: linear-gradient(135deg, #f59e0b, #ec4899);
            border: none;
            padding: 14px 35px;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 700;
            color: white;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(245,158,11,0.4);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid #f59e0b;
            padding: 12px 33px;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 700;
            color: white;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-outline:hover {
            background: #f59e0b;
            transform: translateY(-3px);
        }

        /* ========== FEATURES SECTION ========== */
        .features {
            padding: 80px 20px;
            max-width: 1280px;
            margin: 0 auto;
        }

        .section-title {
            text-align: center;
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 50px;
            background: linear-gradient(135deg, #f59e0b, #ec4899);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .feature-card {
            background: white;
            border-radius: 25px;
            padding: 35px 25px;
            text-align: center;
            transition: all 0.4s;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            cursor: pointer;
        }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        .feature-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #fef3c7, #fde68a);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .feature-icon i {
            font-size: 40px;
            color: #f59e0b;
        }

        .feature-card h3 {
            font-size: 1.3rem;
            margin-bottom: 10px;
            color: #1f2937;
        }

        .feature-card p {
            color: #6b7280;
            font-size: 0.9rem;
            line-height: 1.6;
        }

        /* ========== ABOUT SECTION ========== */
        .about {
            background: linear-gradient(135deg, #fff7ed, #ffedd5);
            padding: 80px 20px;
        }

        .about-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
        }

        .about-content h2 {
            font-size: 2rem;
            margin-bottom: 20px;
            color: #1f2937;
        }

        .about-content h2 span {
            color: #f59e0b;
        }

        .about-content p {
            color: #4b5563;
            line-height: 1.7;
            margin-bottom: 20px;
        }

        .about-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-top: 30px;
        }

        .stat {
            text-align: center;
            padding: 20px;
            background: white;
            border-radius: 20px;
            transition: all 0.3s;
        }

        .stat:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        }

        .stat h3 {
            font-size: 2rem;
            color: #f59e0b;
        }

        .stat p {
            font-size: 0.85rem;
            margin: 0;
        }

        .about-image {
            background: linear-gradient(135deg, #f59e0b, #ec4899);
            border-radius: 30px;
            padding: 40px;
            text-align: center;
            color: white;
        }

        .about-image i {
            font-size: 100px;
            margin-bottom: 20px;
        }

        .about-image h3 {
            font-size: 1.5rem;
            margin-bottom: 10px;
        }

        /* ========== COURSES SECTION ========== */
        .courses {
            padding: 80px 20px;
            max-width: 1280px;
            margin: 0 auto;
        }

        .courses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
        }

        .course-card {
            background: white;
            border-radius: 20px;
            padding: 25px;
            text-align: center;
            transition: all 0.3s;
            cursor: pointer;
            border: 1px solid #fef3c7;
        }

        .course-card:hover {
            transform: translateY(-5px);
            border-color: #f59e0b;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .course-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #fef3c7, #fde68a);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
        }

        .course-icon i {
            font-size: 32px;
            color: #f59e0b;
        }

        .course-card h3 {
            font-size: 1.2rem;
            margin-bottom: 8px;
        }

        .course-card p {
            color: #6b7280;
            font-size: 0.85rem;
        }

        /* ========== NOTICE BOARD ========== */
        .notice {
            background: linear-gradient(135deg, #1e1b4b, #2d1b4e);
            padding: 80px 20px;
            color: white;
        }

        .notice-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
        }

        .notice-board h3, .events h3 {
            font-size: 1.5rem;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .notice-list, .event-list {
            list-style: none;
        }

        .notice-list li, .event-list li {
            padding: 15px 0;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.3s;
            cursor: pointer;
        }

        .notice-list li:hover, .event-list li:hover {
            transform: translateX(5px);
        }

        .notice-list li i, .event-list li i {
            color: #f59e0b;
            font-size: 18px;
        }

        .notice-list li span, .event-list li span {
            font-size: 0.9rem;
        }

        .date {
            font-size: 0.7rem;
            color: #f59e0b;
            margin-left: auto;
        }

        /* ========== FOOTER ========== */
        .footer {
            background: linear-gradient(135deg, #0f172a, #1e1b4b);
            color: #e0e7ff;
            padding: 50px 20px 20px;
        }

        .footer-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
        }

        .footer-col h4 {
            color: #f59e0b;
            margin-bottom: 15px;
        }

        .footer-col a, .footer-col p {
            display: block;
            color: #cbd5e6;
            text-decoration: none;
            font-size: 0.8rem;
            margin-bottom: 8px;
            transition: all 0.3s;
        }

        .footer-col a:hover { color: #f59e0b; transform: translateX(5px); }

        .footer-bottom {
            text-align: center;
            padding-top: 30px;
            margin-top: 30px;
            border-top: 1px solid rgba(245,158,11,0.2);
            font-size: 0.7rem;
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 2rem; }
            .about-container { grid-template-columns: 1fr; }
            .notice-container { grid-template-columns: 1fr; }
            .section-title { font-size: 1.6rem; }
        }
    </style>
</head>
<body>
<%-include('partials/header')%>
<!-- HERO SECTION -->
<section class="hero">
    <div class="hero-content">
        <h1>Welcome to <span>SVIC Inter College</span></h1>
        <p>Empowering minds, shaping futures since 1995. Quality education with modern infrastructure and experienced faculty.</p>
        <div class="hero-buttons">
            <button class="btn-primary" onclick="showToast('🎓 Admission Open 2025-26')"><i class="fas fa-graduation-cap"></i> Apply Now</button>
            <button class="btn-outline" onclick="showToast('📞 Contact us for more information')"><i class="fas fa-phone"></i> Contact Us</button>
        </div>
    </div>
</section>

<!-- FEATURES SECTION -->
<section class="features">
    <h2 class="section-title">Why Choose SVIC?</h2>
    <div class="features-grid">
        <div class="feature-card" onclick="showToast('Quality Education with Experienced Faculty')">
            <div class="feature-icon"><i class="fas fa-chalkboard-user"></i></div>
            <h3>Experienced Faculty</h3>
            <p>Highly qualified and dedicated teachers committed to student success.</p>
        </div>
        <div class="feature-card" onclick="showToast('Modern Labs & Digital Classrooms')">
            <div class="feature-icon"><i class="fas fa-laptop-code"></i></div>
            <h3>Smart Classrooms</h3>
            <p>Digital classrooms with modern teaching aids and technology.</p>
        </div>
        <div class="feature-card" onclick="showToast('100% Placement Assistance')">
            <div class="feature-icon"><i class="fas fa-briefcase"></i></div>
            <h3>Placement Support</h3>
            <p>Career guidance and placement assistance for all students.</p>
        </div>
        <div class="feature-card" onclick="showToast('Sports & Extra Curricular Activities')">
            <div class="feature-icon"><i class="fas fa-futbol"></i></div>
            <h3>Sports & Activities</h3>
            <p>Regular sports events, cultural fests, and competitions.</p>
        </div>
    </div>
</section>

<!-- ABOUT SECTION -->
<section class="about">
    <div class="about-container">
        <div class="about-content">
            <h2>About <span>SVIC Inter College</span></h2>
            <p>SVIC Inter College is a premier educational institution established in 1995 with a vision to provide quality education to students from all backgrounds. Affiliated to UP Board, we offer comprehensive programs in Science, Commerce, and Arts streams.</p>
            <p>Our mission is to nurture young minds with knowledge, discipline, and values that help them become responsible citizens and successful professionals.</p>
            <div class="about-stats">
                <div class="stat"><h3>28+</h3><p>Years of Excellence</p></div>
                <div class="stat"><h3>5000+</h3><p>Students Enrolled</p></div>
                <div class="stat"><h3>100+</h3><p>Qualified Faculty</p></div>
                <div class="stat"><h3>50+</h3><p>Awards Won</p></div>
            </div>
        </div>
        <div class="about-image">
            <i class="fas fa-university"></i>
            <h3>Knowledge · Discipline · Success</h3>
            <p>Building tomorrow's leaders today</p>
        </div>
    </div>
</section>

<!-- COURSES SECTION -->
<section class="courses">
    <h2 class="section-title">Our Courses</h2>
    <div class="courses-grid">
        <div class="course-card" onclick="showToast('Science Stream - PCM/PCB Available')">
            <div class="course-icon"><i class="fas fa-flask"></i></div>
            <h3>Science Stream</h3>
            <p>PCM / PCB with practical labs</p>
        </div>
        <div class="course-card" onclick="showToast('Commerce Stream - Accounts, Economics, Business Studies')">
            <div class="course-icon"><i class="fas fa-chart-line"></i></div>
            <h3>Commerce Stream</h3>
            <p>Accounts, Economics, Business Studies</p>
        </div>
        <div class="course-card" onclick="showToast('Arts Stream - History, Geography, Political Science')">
            <div class="course-icon"><i class="fas fa-palette"></i></div>
            <h3>Arts Stream</h3>
            <p>History, Geography, Political Science</p>
        </div>
        <div class="course-card" onclick="showToast('Computer Science & IT Courses Available')">
            <div class="course-icon"><i class="fas fa-laptop"></i></div>
            <h3>Computer Science</h3>
            <p>Coding, Web Development & More</p>
        </div>
    </div>
</section>

<!-- NOTICE & EVENTS SECTION -->
<section class="notice">
    <div class="notice-container">
        <div class="notice-board">
            <h3><i class="fas fa-bell"></i> Notice Board</h3>
            <ul class="notice-list">
                <li onclick="showToast('Admission Open for 2025-26 session')"><i class="fas fa-file-alt"></i><span>Admission Open 2025-26</span><span class="date">15 Jan</span></li>
                <li onclick="showToast('Annual Exam Schedule Released')"><i class="fas fa-calendar"></i><span>Annual Exam Schedule Released</span><span class="date">10 Mar</span></li>
                <li onclick="showToast('Scholarship Application Deadline Extended')"><i class="fas fa-graduation-cap"></i><span>Scholarship Application Last Date</span><span class="date">31 Mar</span></li>
                <li onclick="showToast('Parent-Teacher Meeting on 25th March')"><i class="fas fa-users"></i><span>Parent-Teacher Meeting</span><span class="date">25 Mar</span></li>
                <li onclick="showToast('Summer Vacation from 15th May')"><i class="fas fa-umbrella-beach"></i><span>Summer Vacation Notice</span><span class="date">01 May</span></li>
            </ul>
        </div>
        <div class="events">
            <h3><i class="fas fa-calendar-alt"></i> Upcoming Events</h3>
            <ul class="event-list">
                <li onclick="showToast('Annual Sports Day on 5th April')"><i class="fas fa-trophy"></i><span>Annual Sports Day</span><span class="date">05 Apr</span></li>
                <li onclick="showToast('Science Exhibition on 12th April')"><i class="fas fa-microscope"></i><span>Science Exhibition</span><span class="date">12 Apr</span></li>
                <li onclick="showToast('Cultural Fest on 20th April')"><i class="fas fa-music"></i><span>Annual Cultural Fest</span><span class="date">20 Apr</span></li>
                <li onclick="showToast('Career Counseling Session on 28th April')"><i class="fas fa-bullhorn"></i><span>Career Counseling Session</span><span class="date">28 Apr</span></li>
            </ul>
        </div>
    </div>
</section>

