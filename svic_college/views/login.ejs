<script>
    function togglePassword(fieldId, icon) {
        const field = document.getElementById(fieldId);
        if (field.type === 'password') {
            field.type = 'text';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        } else {
            field.type = 'password';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        }
    }

    function fillDemoCredentials() {
        document.getElementById('username').value = 'student@svic.edu.in';
        document.getElementById('password').value = 'student123';
        document.getElementById('role').value = 'Student';
        showToast('🔑 Demo credentials filled! Click Login to continue.');
    }

    function submitLogin(event) {
        event.preventDefault();
        
        const username = document.getElementById('username').value;
        const password = document.getElementById('password').value;
        const role = document.getElementById('role').value;
        const rememberMe = document.getElementById('rememberMe').checked;
        
        // Validations
        if (!username) { showToast('❌ Please enter your email or registration ID'); return; }
        if (!password) { showToast('❌ Please enter your password'); return; }
        if (!role) { showToast('❌ Please select your role'); return; }
        
        // Demo validation
        let userRole = '';
        if (username === 'student@svic.edu.in' && password === 'student123') {
            userRole = 'Student';
        } else if (username === 'parent@svic.edu.in' && password === 'parent123') {
            userRole = 'Parent';
        } else {
            showToast('❌ Invalid credentials! Please check your email/ID and password');
            return;
        }
        
        if (role !== userRole) {
            showToast(`❌ Role mismatch! Please select "${userRole}" as your role`);
            return;
        }
        
        // Success message
        const dashboardUrl = role === 'Student' ? 'Student Dashboard' : role === 'Parent' ? 'Parent Dashboard' : 'Dashboard';
        
        alert(`✅ Login Successful!\n\nWelcome ${username}!\nRole: ${role}\n\nRedirecting to ${dashboardUrl}...\n\nThis is a demo login. Full portal access will be available soon.`);
        
        showToast(`🎉 Welcome back! Redirecting to ${dashboardUrl}...`);
        
        if (rememberMe) {
            localStorage.setItem('savedUsername', username);
            localStorage.setItem('savedRole', role);
        } else {
            localStorage.removeItem('savedUsername');
            localStorage.removeItem('savedRole');
        }
        
        // Log to console
        console.log({ username, role, loginTime: new Date().toISOString(), rememberMe });
        
        // Reset form (optional)
        // document.getElementById('loginForm').reset();
    }
    
    // Load saved username if exists
    window.addEventListener('load', () => {
        const savedUsername = localStorage.getItem('savedUsername');
        const savedRole = localStorage.getItem('savedRole');
        if (savedUsername) {
            document.getElementById('username').value = savedUsername;
            if (savedRole) document.getElementById('role').value = savedRole;
            document.getElementById('rememberMe').checked = true;
        }
    });

    function openMobileMenu() {
        document.getElementById('mobileMenu').classList.add('active');
        document.getElementById('screenOverlay').classList.add('active');
        document.body.style.overflow = 'hidden';
    }
    
    function closeMobileMenu() {
        document.getElementById('mobileMenu').classList.remove('active');
        document.getElementById('screenOverlay').classList.remove('active');
        document.body.style.overflow = '';
    }
    
    function showToast(message) {
        const toast = document.createElement('div');
        toast.innerHTML = `<div style="position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#1e1b4b;color:white;padding:12px 25px;border-radius:50px;font-size:14px;z-index:10000;box-shadow:0 5px 20px rgba(0,0,0,0.2);animation:fadeInUp 0.3s ease;">${message}</div>`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
    
    const style = document.createElement('style');
    style.textContent = `@keyframes fadeInUp { from { opacity:0; transform:translateX(-50%) translateY(20px); } to { opacity:1; transform:translateX(-50%) translateY(0); } }`;
    document.head.appendChild(style);
    
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMobileMenu(); });
    window.addEventListener('resize', () => { if (window.innerWidth > 992) closeMobileMenu(); });
    
    console.log("✅ Login Page Loaded - Fully Responsive & Interactive");
</script>
<%-include('partials/footer')%>
</body>
</html>