<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>MSD Public School | Admission Application (Class 9-12) - Full Screen</title>
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    
 <link rel="stylesheet" href="/svic_college/css/admission.css">
</head>
<body>
    <%- include('partials/header') %>

<!-- Background Particles -->
<div class="bg-particles" id="particles"></div>

<section class="admission-section" id="admission">
    <div class="admission-container">
      
        <div class="admission-form">
            <div id="formMessage" class="alert-message"></div>
            
            <form id="admissionForm" method="POST" enctype="multipart/form-data">
                <!-- Student Information Section -->
                <div class="section-title"><i class="fas fa-user-graduate"></i> Student Information</div>
                <div class="form-row">
                    <div class="form-group" id="group-studentName">
                        <label><i class="fas fa-user"></i> Student's Full Name <span class="required">*</span></label>
                        <input type="text" name="student_name" id="student_name" required placeholder="Enter student's full name">
                    </div>
                    <div class="form-group" id="group-dob">
                        <label><i class="fas fa-calendar-alt"></i> Date of Birth <span class="required">*</span></label>
                        <input type="date" name="dob" id="dob" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" id="group-gender">
                        <label><i class="fas fa-venus-mars"></i> Gender <span class="required">*</span></label>
                        <select name="gender" id="gender" required>
                            <option value="">-- Select Gender --</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="form-group" id="group-category">
                        <label><i class="fas fa-tag"></i> Category</label>
                        <select name="category" id="category">
                            <option value="">-- Select Category --</option>
                            <option>General</option>
                            <option>OBC</option>
                            <option>SC</option>
                            <option>ST</option>
                            <option>EWS</option>
                        </select>
                    </div>
                </div>

                <!-- Class Selection -->
                <div class="class-group" id="group-class">
                    <label><i class="fas fa-chalkboard"></i> Applying for Class <span class="required">*</span></label>
                    <div class="class-options">
                        <div class="class-option">
                            <input type="radio" name="class_applying" id="class9" value="9">
                            <label for="class9">Class 9</label>
                        </div>
                        <div class="class-option">
                            <input type="radio" name="class_applying" id="class10" value="10">
                            <label for="class10">Class 10</label>
                        </div>
                        <div class="class-option">
                            <input type="radio" name="class_applying" id="class11" value="11">
                            <label for="class11">Class 11</label>
                        </div>
                        <div class="class-option">
                            <input type="radio" name="class_applying" id="class12" value="12">
                            <label for="class12">Class 12</label>
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" id="group-stream">
                        <label><i class="fas fa-book-open"></i> Preferred Stream <span class="required" id="streamRequired">*</span></label>
                        <select name="stream" id="stream">
                            <option value="">-- Select Stream --</option>
                            <option>Science (PCM)</option>
                            <option>Science (PCB)</option>
                            <option>Commerce</option>
                            <option>Arts/Humanities</option>
                        </select>
                        <small id="streamNote" style="color:#64748b;">For Class 11 & 12 only</small>
                    </div>
                    <div class="form-group" id="group-previousSchool">
                        <label><i class="fas fa-school"></i> Previous School Name</label>
                        <input type="text" name="previous_school" id="previous_school" placeholder="Last attended school">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" id="group-percentage">
                        <label><i class="fas fa-chart-line"></i> Last Exam Percentage (%)</label>
                        <input type="number" name="percentage" id="percentage" step="0.01" min="0" max="100" placeholder="e.g., 85.5">
                    </div>
                    <div class="form-group" id="group-board">
                        <label><i class="fas fa-building"></i> Board</label>
                        <select name="board" id="board">
                            <option value="">-- Select Board --</option>
                            <option>CBSE</option>
                            <option>ICSE</option>
                            <option>UP Board</option>
                            <option>Other State Board</option>
                        </select>
                    </div>
                </div>

                <!-- Parent Information Section -->
                <div class="section-title"><i class="fas fa-users"></i> Parent / Guardian Information</div>
                <div class="form-row">
                    <div class="form-group" id="group-fatherName">
                        <label><i class="fas fa-father"></i> Father's Name <span class="required">*</span></label>
                        <input type="text" name="father_name" id="father_name" required placeholder="Father's full name">
                    </div>
                    <div class="form-group" id="group-motherName">
                        <label><i class="fas fa-mother"></i> Mother's Name <span class="required">*</span></label>
                        <input type="text" name="mother_name" id="mother_name" required placeholder="Mother's full name">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" id="group-parentMobile">
                        <label><i class="fas fa-phone-alt"></i> Parent Mobile Number <span class="required">*</span></label>
                        <input type="tel" name="parent_mobile" id="parent_mobile" pattern="[0-9]{10}" required placeholder="9876543210" maxlength="10">
                    </div>
                    <div class="form-group" id="group-parentEmail">
                        <label><i class="fas fa-envelope"></i> Parent Email Address <span class="required">*</span></label>
                        <input type="email" name="parent_email" id="parent_email" required placeholder="parent@example.com">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" id="group-occupation">
                        <label><i class="fas fa-briefcase"></i> Father's Occupation</label>
                        <input type="text" name="occupation" id="occupation" placeholder="e.g., Business, Government Service">
                    </div>
                    <div class="form-group" id="group-annualIncome">
                        <label><i class="fas fa-rupee-sign"></i> Annual Family Income</label>
                        <select name="annual_income" id="annual_income">
                            <option value="">-- Select Income Range --</option>
                            <option>Below 2 Lakhs</option>
                            <option>2-5 Lakhs</option>
                            <option>5-10 Lakhs</option>
                            <option>Above 10 Lakhs</option>
                        </select>
                    </div>
                </div>

                <!-- Address Section -->
                <div class="section-title"><i class="fas fa-map-marker-alt"></i> Address</div>
                <div class="form-group" id="group-address">
                    <label>Residential Address <span class="required">*</span></label>
                    <textarea name="address" id="address" rows="3" required placeholder="Enter complete address with city, district, pin code"></textarea>
                    <div class="char-counter" id="addressCounter">0/300 characters</div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-city"></i> City</label>
                        <input type="text" name="city" id="city" placeholder="City">
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-code-branch"></i> Pin Code</label>
                        <input type="text" name="pincode" id="pincode" placeholder="Pin Code" maxlength="6">
                    </div>
                </div>

                <!-- Documents Section -->
                <div class="section-title"><i class="fas fa-folder-open"></i> Documents (Optional)</div>
                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-id-card"></i> Birth Certificate (PDF)</label>
                        <input type="file" name="birth_certificate" id="birth_certificate" accept=".pdf">
                        <small>Max 2MB</small>
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-graduation-cap"></i> Last Marksheet (PDF)</label>
                        <input type="file" name="marksheet" id="marksheet" accept=".pdf">
                        <small>Max 2MB</small>
                    </div>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-passport"></i> Student Photo (JPG/PNG)</label>
                    <input type="file" name="student_photo" id="student_photo" accept="image/jpeg,image/png">
                    <small>Recent passport size photo (Max 2MB)</small>
                </div>

                <button type="submit" class="submit-btn" id="submitBtn">
                    <i class="fas fa-paper-plane"></i> Submit Admission Application
                    <i class="fas fa-arrow-right"></i>
                </button>
            </form>
        </div>
    </div>
</section>

<script src="/js/admission.js"></script>
 <%- include('partials/footer') %>
</body>
</html>