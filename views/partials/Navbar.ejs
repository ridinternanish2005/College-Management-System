              <li><i class="fas fa-check-circle"></i> Digital Library with 5000+ Journals</li>
              <li><i class="fas fa-check-circle"></i> Research & Innovation Center</li>
              <li><i class="fas fa-check-circle"></i> 95% University Exam Success Rate</li>
            </ul>
          </div>
        </div>

        <div class="feature-card">
