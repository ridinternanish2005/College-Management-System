  <!-- ===== JAVASCRIPT ===== -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {

      // --- Hamburger Toggle ---
      const menuToggle = document.getElementById('menuToggle');
      const mainMenu = document.getElementById('innerCont');
      const body = document.body;

      menuToggle.addEventListener('click', function(e) {
        e.stopPropagation();
        const isActive = mainMenu.classList.toggle('active');
        menuToggle.classList.toggle('active');
        body.classList.toggle('menu-open');
        menuToggle.setAttribute('aria-expanded', isActive);
      });

      // Close menu on outside click
      document.addEventListener('click', function(e) {
        const isClickInside = mainMenu.contains(e.target) || menuToggle.contains(e.target);
        if (!isClickInside && mainMenu.classList.contains('active')) {
          mainMenu.classList.remove('active');
          menuToggle.classList.remove('active');
          body.classList.remove('menu-open');
          menuToggle.setAttribute('aria-expanded', 'false');
        }
      });

      // Close menu on Escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && mainMenu.classList.contains('active')) {
          mainMenu.classList.remove('active');
          menuToggle.classList.remove('active');
          body.classList.remove('menu-open');
          menuToggle.setAttribute('aria-expanded', 'false');
        }
      });

      // --- Login / Register Slider ---
      const btnBox = document.getElementById('btnBox');
      const logInBtn = document.getElementById('logInButton');
      const signUpBtn = document.getElementById('signUpBtn');

      let isLoginActive = true;

      function updateLoginState(login) {
        isLoginActive = login;
        if (login) {
          btnBox.classList.remove('signup-active');
          logInBtn.style.color = '#fff';
          signUpBtn.style.color = '#000';
        } else {
          btnBox.classList.add('signup-active');
          logInBtn.style.color = '#000';
          signUpBtn.style.color = '#fff';
        }
      }

      logInBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        if (!isLoginActive) updateLoginState(true);
      });

      signUpBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        if (isLoginActive) updateLoginState(false);
      });

      // --- Dropdown toggles for mobile/tablet ---
      const dropdownToggles = document.querySelectorAll('.dropdown-toggle');
      dropdownToggles.forEach(function(toggle) {
        toggle.addEventListener('click', function(e) {
          if (window.innerWidth < 992) {
            e.preventDefault();
            const parentDropdown = toggle.closest('.dropdown');
            if (parentDropdown) {
              parentDropdown.classList.toggle('active');
            }
          }
        });
      });

      // Close other dropdowns when one is opened (mobile)
      document.addEventListener('click', function(e) {
        if (window.innerWidth < 992) {
          document.querySelectorAll('.dropdown').forEach(function(dd) {
            if (!dd.contains(e.target)) {
              dd.classList.remove('active');
            }
          });
        }
      });

      // --- Reset on resize to desktop ---
      let resizeTimer;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function() {
          if (window.innerWidth >= 992) {
            if (mainMenu.classList.contains('active')) {
              mainMenu.classList.remove('active');
              menuToggle.classList.remove('active');
              body.classList.remove('menu-open');
              menuToggle.setAttribute('aria-expanded', 'false');
            }
            document.querySelectorAll('.dropdown').forEach(function(dd) {
              dd.classList.remove('active');
            });
          }
        }, 200);
      });

      // --- Init ---
      updateLoginState(true);
      if (window.innerWidth < 992) {
        mainMenu.classList.remove('active');
        menuToggle.classList.remove('active');
        body.classList.remove('menu-open');
        menuToggle.setAttribute('aria-expanded', 'false');
      }
    });
  </script>
 

