<body>

<div class="container">

    <!-- LEFT INFO -->
    <div class="college-info">
        <h1>Maa Maturani Devi Pharmacy College</h1>
        <p>College Management System</p>
        <p>Student | Faculty | Admin Portal</p>
    </div>

    <!-- LOGIN -->
    <div class="login-section">
        <h2>Login</h2>

        <form id="loginForm">

            <label>User Type</label>
            <select id="userType" class="form-control" required>
                <option value="" disabled selected>Select user</option>
               <a href="/students"> <option value="student">Student</option> </a>
                <option value="faculty">Faculty</option>
                <option value="admin">Admin</option>
                <option value="principal">Principal</option>
            </select>

            <label>Session</label>
            <select id="session" class="form-control" required>
                <option value="2024-25" selected>2024-25</option>
                <option value="2025-26">2025-26</option>
            </select>

            <label>Username / Enrollment</label>
            <input type="text" id="username" class="form-control" placeholder="Enter username" required>

            <label>Password</label>
            <input type="password" id="password" class="form-control" placeholder="Enter password" required>

            <button type="submit" class="btn-login">
                <i class="fas fa-sign-in-alt"></i> Login
            </button>

        </form>
    </div>
</div>

<!-- ================= SCRIPT ================= -->
<script>
document.getElementById("loginForm").addEventListener("submit", function (e) {
    e.preventDefault();

    const userType = document.getElementById("userType").value;
    const session = document.getElementById("session").value;
    const username = document.getElementById("username").value;
    const password = document.getElementById("password").value;

    if (!userType || !session || !username || !password) {
        alert("Please fill all fields");
        return;
    }

    alert("Login Successful!");

    const redirectPage = {
        student: "/erp/student",
        faculty: "/erp/faculty",
        admin: "/erp/admin",
        principal: "/erp/principal"
    };

    window.location.href = redirectPage[userType] ||"dashboard.html";
});
</script>
