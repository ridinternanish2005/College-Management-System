              <th>Sub-V</th><th>Attend-V</th><th>Sub-VI</th><th>Attend-VI</th>
            </tr>
          </thead>
          <tbody>
            <tr class="attendance-note-row">
              <td class="note-board-cell">
                📌 <strong>Note Board</strong>
                <span id="noticeCounterBadge" class="current-notice-badge">1/7</span>
              </td>
              <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
              <td><button class="next-btn" id="nextNotice1">NEXT</button></td>
              <td><button class="next-btn" id="nextNotice2">NEXT</button></td>
            </tr>
          </tbody>
        </table>
      </div>
      <!-- Last Five Transactions -->
