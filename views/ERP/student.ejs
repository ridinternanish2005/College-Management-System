      <div class="table-responsive">
        <table>
          <thead><tr><th>Date</th><th>Receipt No.</th><th>Amount</th></tr></thead>
          <tbody>
            <tr><td>30-09-2023</td><td>202233979</td><td>500</td></tr>
            <tr><td>03-10-2023</td><td>202234140</td><td>3000</td></tr>
            <tr><td>11-10-2023</td><td>202234934</td><td>250</td></tr>
