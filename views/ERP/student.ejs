<!-- ========== SCRIPT: SIDEBAR NAVIGATION + GO/NOTICE FUNCTIONALITY ========== -->
<script>
  (function() {
    "use strict";

    // ------- SIDEBAR NAVIGATION -------
    const navItems = document.querySelectorAll('.nav-item');
    const views = document.querySelectorAll('.view');

    function activateView(viewId) {
      // hide all views
      views.forEach(v => v.classList.remove('active-view'));
      // show selected
      const activeView = document.getElementById(viewId);
      if (activeView) activeView.classList.add('active-view');
    }

    navItems.forEach(item => {
      item.addEventListener('click', function(e) {
        // remove active class from all nav items
        navItems.forEach(nav => nav.classList.remove('active'));
        // add active to clicked item
        this.classList.add('active');
        // get target view
        const viewId = this.getAttribute('data-view');
        if (viewId) activateView(viewId);
      });
    });

    // ------- ORIGINAL DASHBOARD FUNCTIONALITY (GO, NEXT) -------
    const goBtn = document.getElementById('goBtn');
    const nextBtn1 = document.getElementById('nextNotice1');
    const nextBtn2 = document.getElementById('nextNotice2');
    const noticeRows = document.querySelectorAll('#noticeTableBody tr');
    const noticeCounterBadge = document.getElementById('noticeCounterBadge');

    let currentNoticeIndex = 0;
    const totalNotices = noticeRows.length; // 7

    function clearHighlight() {
      noticeRows.forEach(row => row.classList.remove('note-highlight'));
    }

    function updateNoticeDisplay(index) {
      if (totalNotices === 0) return;
      index = (index % totalNotices + totalNotices) % totalNotices;
      currentNoticeIndex = index;
      clearHighlight();
      if (noticeRows[currentNoticeIndex]) {
        noticeRows[currentNoticeIndex].classList.add('note-highlight');
      }
      if (noticeCounterBadge) {
        noticeCounterBadge.textContent = `${currentNoticeIndex+1}/${totalNotices}`;
      }
    }

    function nextNotice() {
      if (totalNotices === 0) return;
      let newIndex = currentNoticeIndex + 1;
      if (newIndex >= totalNotices) newIndex = 0;
      updateNoticeDisplay(newIndex);
    }

    // initial highlight
    if (totalNotices > 0) updateNoticeDisplay(0);

    // GO button
    if (goBtn) {
      goBtn.addEventListener('click', function(e) {
        e.preventDefault();
        alert('🚀 GO clicked! ERP session 2023-24 · Redirecting to dashboard.');
      });
    }

    // NEXT buttons
    if (nextBtn1) nextBtn1.addEventListener('click', (e) => { e.preventDefault(); nextNotice(); });
    if (nextBtn2) nextBtn2.addEventListener('click', (e) => { e.preventDefault(); nextNotice(); });

  })();
</script>

