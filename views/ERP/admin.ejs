<!-- ========== SCRIPT: SIDEBAR NAVIGATION + GO BUTTON ========== -->
<script>
  (function() {
    "use strict";
    const navItems = document.querySelectorAll('.nav-item');
    const views = document.querySelectorAll('.view');

    function activateView(viewId) {
      views.forEach(v => v.classList.remove('active-view'));
      const activeView = document.getElementById(viewId);
      if (activeView) activeView.classList.add('active-view');
    }

    navItems.forEach(item => {
      item.addEventListener('click', function(e) {
        navItems.forEach(nav => nav.classList.remove('active'));
        this.classList.add('active');
        const viewId = this.getAttribute('data-view');
        if (viewId) activateView(viewId);
      });
    });

    const goBtn = document.getElementById('goBtn');
    if (goBtn) {
      goBtn.addEventListener('click', function(e) {
        e.preventDefault();
        alert('🚀 GO · Admin Dashboard · Session 2023-24');
      });
    }

    // Ensure default view is active
    if (!document.querySelector('.view.active-view')) {
      document.getElementById('dashboardView')?.classList.add('active-view');
    }
  })();
</script>

