<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=2.0, user-scalable=yes">
  <title>Admin Dashboard · Maa Maturani Devi Pharmacy College</title>
  <!-- Google Font & Font Awesome Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    /* ----- GLOBAL RESET – MOBILE FIRST ----- */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #e9ecf1;
      color: #1a2639;
      line-height: 1.5;
      -webkit-tap-highlight-color: transparent;
    }

    /* ----- DASHBOARD LAYOUT – FLEXIBLE ----- */
    .dashboard-wrapper {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      max-width: 1600px;
      margin: 0 auto;
      background: #f8fafd;
      box-shadow: 0 0 30px rgba(0,0,0,0.03);
    }

    /* ===== SIDEBAR – ADMIN NAVIGATION, RESPONSIVE ===== */
    .sidebar {
      width: 100%;
      background: linear-gradient(180deg, #0a2a3f 0%, #0d344b 100%);
      color: #e7f0f9;
      display: flex;
      flex-direction: column;
      padding: 20px 16px;
      transition: all 0.2s;
    }

    .sidebar-header {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 16px;
      border-bottom: 1px solid #2e4e64;
      margin-bottom: 16px;
    }

    .erp-code-big {
      font-size: 1.3rem;
      font-weight: 700;
      color: white;
      letter-spacing: -0.5px;
    }

    .erp-session-badge {
      background: #1e4f6b;
      padding: 4px 14px;
      border-radius: 30px;
      font-size: 0.8rem;
      font-weight: 500;
      color: white;
      border: 1px solid #3d7e9a;
      white-space: nowrap;
    }

    .nav-caption {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-weight: 600;
      color: #9bbad0;
      margin-bottom: 12px;
    }

    .admin-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: space-between;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      border-radius: 40px;
      font-weight: 500;
      color: #cbdbe8;
      transition: all 0.18s;
      cursor: pointer;
      font-size: 0.9rem;
      flex: 0 1 auto;
      background: rgba(255,255,255,0.05);
      min-height: 44px;
    }

    .nav-item i {
      width: 20px;
      text-align: center;
      font-size: 1rem;
      color: #aac7db;
    }

    .nav-item.active {
      background: #1e4f6b;
      color: white;
      box-shadow: 0 4px 8px rgba(0,30,50,0.2);
    }

    .nav-item.active i {
      color: white;
    }

    .nav-item:not(.active):hover {
      background: #1f4459;
      color: white;
    }

    .sidebar-footer {
      margin-top: 24px;
      padding-top: 16px;
      border-top: 1px solid #2e4e64;
      font-size: 0.75rem;
      color: #adc4d6;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
    }

    /* ===== MAIN CONTENT – FULLY FLEXIBLE ===== */
    .main-content {
      flex: 1;
      padding: 20px 16px;
      background: #f4f7fc;
      overflow-x: hidden;
      display: flex;
      flex-direction: column;
    }

    /* Persistent header */
    .erp-header {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
      gap: 12px;
    }

    .erp-title {
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: -0.4px;
      color: #0b2f4e;
    }

    .erp-code-area {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 12px;
      background: #f0f4fa;
      padding: 6px 16px;
      border-radius: 40px;
    }

    .erp-code {
      font-weight: 600;
      color: #1e3b5a;
      font-size: 0.9rem;
    }

    .erp-session {
      background: #2c3e50;
      color: white;
      padding: 4px 14px;
      border-radius: 30px;
      font-size: 0.85rem;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      white-space: nowrap;
    }

    #goBtn {
      background: #0066cc;
      border: none;
      color: white;
      font-weight: 600;
      padding: 4px 16px;
      border-radius: 30px;
      font-size: 0.85rem;
      cursor: pointer;
      transition: 0.15s;
      border: 1px solid #ffffff30;
    }

    #goBtn:hover {
      background: #004c99;
    }

    /* Dynamic views */
    .view {
      display: none;
      width: 100%;
    }

    .view.active-view {
      display: block;
    }

    /* ----- ADMIN DASHBOARD STYLES – MOBILE OPTIMIZED ----- */
    .page-title {
      font-size: 1.6rem;
      font-weight: 600;
      margin: 16px 0 16px 0;
      color: #0b2f4e;
      border-left: 6px solid #2a7faa;
      padding-left: 14px;
      word-break: break-word;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
      margin: 20px 0 24px;
    }

    .stat-card {
      background: #ffffff;
      border-radius: 18px;
      padding: 18px 16px;
      box-shadow: 0 3px 10px rgba(0,0,0,0.02);
      border: 1px solid #e9edf4;
    }

    .stat-label {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      font-weight: 600;
      color: #4a657d;
    }

    .stat-number {
      font-size: 2rem;
      font-weight: 700;
      color: #0e3b5c;
      line-height: 1;
      margin-top: 6px;
    }

    .stat-sub {
      font-size: 0.8rem;
      color: #3f6983;
      margin-top: 4px;
    }

    .row-2col, .row-3col {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      margin-top: 20px;
    }

    .card {
      background: white;
      border-radius: 20px;
      padding: 20px;
      border: 1px solid #e2eaf1;
      box-shadow: 0 4px 10px rgba(0,0,0,0.01);
      word-wrap: break-word;
    }

    .card-title {
      font-size: 1.2rem;
      font-weight: 600;
      color: #1e3b5a;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .badge {
      background: #eef3f9;
      padding: 4px 12px;
      border-radius: 30px;
      font-size: 0.75rem;
      font-weight: 600;
      color: #004d7c;
      white-space: nowrap;
    }

    .badge-success {
      background: #dff0d8;
      color: #2e6b3e;
    }
    .badge-warning {
      background: #fcf8e3;
      color: #8a6d3b;
    }

    .admin-item {
      padding: 12px 0;
      border-bottom: 1px solid #edf2f7;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .admin-item:last-child {
      border-bottom: none;
    }

    .btn-outline, .btn-primary {
      padding: 10px 18px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.9rem;
      cursor: pointer;
      transition: 0.15s;
      border: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      white-space: nowrap;
      width: 100%;
      margin-bottom: 8px;
      min-height: 44px;
    }

    .btn-outline {
      background: transparent;
      border: 1.5px solid #1e4a6b;
      color: #1e4a6b;
    }

    .btn-primary {
      background: #1e4a6b;
      color: white;
    }

    .btn-outline:hover {
      background: #1e4a6b;
      color: white;
    }

    .btn-primary:hover {
      background: #0e3d5e;
    }

    .table-responsive {
      overflow-x: auto;
      margin: 16px 0;
      border-radius: 16px;
      border: 1px solid #dfe6ed;
      background: white;
      -webkit-overflow-scrolling: touch;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
      min-width: 600px;
    }

    th {
      background: #eef3f9;
      font-weight: 600;
      color: #1f3a57;
      padding: 12px 10px;
      white-space: nowrap;
    }

    td {
      padding: 12px 10px;
      border-bottom: 1px solid #e3eaf0;
    }

    .form-control, .form-select {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid #cbd6e2;
      border-radius: 30px;
      font-size: 0.95rem;
      background: white;
      font-family: inherit;
    }

    .fee-progress {
      background: #eaeef3;
      height: 10px;
      border-radius: 20px;
      margin: 12px 0;
    }

    .footer-copy {
      margin-top: 40px;
      padding-top: 20px;
      border-top: 2px solid #dce3ec;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      color: #4e627c;
      font-size: 0.8rem;
      text-align: center;
    }

    /* ===== TABLET & DESKTOP ENHANCEMENTS ===== */
    @media (min-width: 640px) {
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .row-2col {
        grid-template-columns: repeat(2, 1fr);
      }
      .btn-outline, .btn-primary {
        width: auto;
        margin-bottom: 0;
      }
      .admin-item {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
      }
      .sidebar-footer {
        flex-direction: row;
      }
    }

    @media (min-width: 768px) {
      .dashboard-wrapper {
        flex-direction: row;
      }
      .sidebar {
        width: 280px;
        padding: 28px 20px;
      }
      .sidebar-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }
      .erp-code-big {
        font-size: 1.6rem;
      }
      .admin-nav {
        flex-direction: column;
        flex-wrap: nowrap;
      }
      .nav-item {
        width: 100%;
        border-radius: 14px;
        padding: 12px 20px;
      }
      .stats-grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 22px;
      }
      .page-title {
        font-size: 1.9rem;
      }
    }

    @media (min-width: 1024px) {
      .row-3col {
        grid-template-columns: repeat(3, 1fr);
      }
      .main-content {
        padding: 28px 32px;
      }
    }
  </style>
</head>
<body>
<div class="dashboard-wrapper">
  <!-- ========== SIDEBAR – ADMIN NAVIGATION (RESPONSIVE) ========== -->
  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="erp-code-big">34987 (2023-24)</div>
      <span class="erp-session-badge">2023-24</span>
    </div>
    <div class="nav-caption">ADMIN PANEL</div>
    <div class="admin-nav">
      <div class="nav-item active" data-view="dashboardView">
        <i class="fas fa-tachometer-alt"></i>
        <span>Dashboard</span>
      </div>
      <div class="nav-item" data-view="userManagementView">
        <i class="fas fa-users-cog"></i>
        <span>User Management</span>
      </div>
      <div class="nav-item" data-view="courseManagementView">
        <i class="fas fa-book"></i>
        <span>Course Management</span>
      </div>
      <div class="nav-item" data-view="departmentView">
        <i class="fas fa-building"></i>
        <span>Departments</span>
      </div>
      <div class="nav-item" data-view="feeManagementView">
        <i class="fas fa-coins"></i>
        <span>Fee Management</span>
      </div>
      <div class="nav-item" data-view="attendanceOverviewView">
        <i class="fas fa-calendar-check"></i>
        <span>Attendance</span>
      </div>
      <div class="nav-item" data-view="noticesView">
        <i class="fas fa-bullhorn"></i>
        <span>Notices</span>
      </div>
      <div class="nav-item" data-view="reportsView">
        <i class="fas fa-chart-pie"></i>
        <span>Reports</span>
      </div>
      <div class="nav-item" data-view="systemSettingsView">
        <i class="fas fa-cogs"></i>
        <span>System Settings</span>
      </div>
      <div class="nav-item" data-view="changePwdView">
        <i class="fas fa-key"></i>
        <span>Change Password</span>
      </div>
    </div>
    <div class="sidebar-footer">
      <div style="display:flex; align-items:center; gap:8px;">
        <i class="fas fa-user-tie"></i>
        <span>Admin • MMDPC</span>
      </div>
      <div style="font-size:0.7rem;">
        <i class="far fa-copyright"></i> Maa Maturani Devi Pharmacy College
      </div>
    </div>
  </aside>

  <!-- ========== MAIN CONTENT – RESPONSIVE ========== -->
  <main class="main-content">
    <!-- Persistent Header -->
    <div class="erp-header">
      <div class="erp-title">CollegeERP</div>
      <div class="erp-code-area">
        <span class="erp-code">34987 (23-24)</span>
        <span class="erp-session">
          2023-24
          <button id="goBtn">GO</button>
        </span>
      </div>
    </div>

    <!-- ===== ADMIN DYNAMIC VIEWS (ALL RESPONSIVE) ===== -->
    <!-- 1. DASHBOARD VIEW (Overview) -->
    <div id="dashboardView" class="view active-view">
      <div class="page-title">Admin Dashboard</div>
      
      <!-- Key Institutional Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Total Students</div>
          <div class="stat-number">1,284</div>
          <div class="stat-sub">↑ 6% from last sem</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Total Faculty</div>
          <div class="stat-number">86</div>
          <div class="stat-sub">Professors: 24, Asst: 62</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Staff</div>
          <div class="stat-number">42</div>
          <div class="stat-sub">Admin & Support</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Courses</div>
          <div class="stat-number">14</div>
          <div class="stat-sub">UG: 8, PG: 6</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Today's Attendance</div>
          <div class="stat-number">87%</div>
          <div class="stat-sub">↑ 2% vs yesterday</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Pending Approvals</div>
          <div class="stat-number">12</div>
          <div class="stat-sub">Faculty leave: 5, Student: 7</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Fee Collection</div>
          <div class="stat-number">₹48.7L</div>
          <div class="stat-sub">78% of target</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Due Amount</div>
          <div class="stat-number">₹13.8L</div>
          <div class="stat-sub">23 defaulters</div>
        </div>
      </div>

      <!-- Two column: Recent Registrations & Pending Approvals -->
      <div class="row-2col">
        <div class="card">
          <div class="card-title">
            <i class="fas fa-user-plus"></i> Recent Registrations
          </div>
          <div class="admin-item">
            <span><strong>PHT2026001</strong> Kavya Mishra</span>
            <span class="badge">B.Pharm I</span>
            <span style="font-size:0.8rem;">Today</span>
          </div>
          <div class="admin-item">
            <span><strong>PHT2026002</strong> Rohit Sahu</span>
            <span class="badge">Pharm.D I</span>
            <span style="font-size:0.8rem;">Yesterday</span>
          </div>
          <div class="admin-item">
            <span><strong>FAC089</strong> Dr. Neha Rathore</span>
            <span class="badge">Asst. Professor</span>
            <span style="font-size:0.8rem;">15 Feb</span>
          </div>
          <button class="btn-outline" style="margin-top:16px;" onclick="alert('View all users (demo)')">View All</button>
        </div>
        <div class="card">
          <div class="card-title">
            <i class="fas fa-clock"></i> Pending Approvals
          </div>
          <div class="admin-item">
            <span>Faculty Leave (Dr. Gupta)</span>
            <span class="badge badge-warning">2 days</span>
            <button class="btn-outline" style="padding:4px 12px; width:auto;" onclick="alert('Approve (demo)')">Approve</button>
          </div>
          <div class="admin-item">
            <span>Student Hostel Opt (Priya)</span>
            <span class="badge badge-warning">Pending</span>
            <button class="btn-outline" style="padding:4px 12px; width:auto;" onclick="alert('Approve (demo)')">Review</button>
          </div>
          <div class="admin-item">
            <span>Fee Concession (Anjali)</span>
            <span class="badge badge-warning">Request</span>
            <button class="btn-outline" style="padding:4px 12px; width:auto;" onclick="alert('Process (demo)')">Process</button>
          </div>
        </div>
      </div>

      <!-- Quick Actions & System Health -->
      <div class="row-2col" style="margin-top:20px;">
        <div class="card">
          <div class="card-title"><i class="fas fa-bolt"></i> Quick Actions</div>
          <div style="display:flex; flex-wrap:wrap; gap:12px;">
            <button class="btn-primary" onclick="alert('Add new user (demo)')"><i class="fas fa-user-plus"></i> Add User</button>
            <button class="btn-outline" onclick="alert('Create notice (demo)')"><i class="fas fa-bullhorn"></i> New Notice</button>
            <button class="btn-outline" onclick="alert('Generate report (demo)')"><i class="fas fa-chart-bar"></i> Reports</button>
          </div>
        </div>
        <div class="card">
          <div class="card-title"><i class="fas fa-shield-alt"></i> System Health</div>
          <div style="display:flex; justify-content:space-between;">
            <span>ERP Uptime</span>
            <strong>99.9%</strong>
          </div>
          <div style="display:flex; justify-content:space-between; margin-top:8px;">
            <span>Backup</span>
            <strong>16 Feb 2026</strong>
          </div>
          <div style="display:flex; justify-content:space-between; margin-top:8px;">
            <span>Active Sessions</span>
            <strong>342</strong>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. USER MANAGEMENT VIEW -->
    <div id="userManagementView" class="view">
      <div class="page-title">User Management</div>
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-label">Students</div><div class="stat-number">1,284</div></div>
        <div class="stat-card"><div class="stat-label">Faculty</div><div class="stat-number">86</div></div>
        <div class="stat-card"><div class="stat-label">Staff</div><div class="stat-number">42</div></div>
        <div class="stat-card"><div class="stat-label">Pending</div><div class="stat-number">12</div></div>
      </div>
      <div class="card">
        <div class="card-title">User Directory & Controls</div>
        <div style="display:flex; flex-wrap:wrap; gap:12px; margin-bottom:20px;">
          <button class="btn-primary" onclick="alert('Add Student (demo)')"><i class="fas fa-user-graduate"></i> Add Student</button>
          <button class="btn-primary" onclick="alert('Add Faculty (demo)')"><i class="fas fa-chalkboard-teacher"></i> Add Faculty</button>
          <button class="btn-outline" onclick="alert('Import users (demo)')"><i class="fas fa-file-import"></i> Import</button>
        </div>
        <div class="table-responsive">
          <table>
            <thead><tr><th>ID</th><th>Name</th><th>Role</th><th>Department</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
              <tr><td>PHT30101</td><td>Aarav Sharma</td><td>Student</td><td>B.Pharm</td><td><span class="badge badge-success">Active</span></td><td><button class="btn-outline" style="padding:4px 12px;" onclick="alert('Edit user (demo)')">Edit</button></td></tr>
              <tr><td>FAC001</td><td>Dr. Alka Verma</td><td>Professor</td><td>Pharmaceutics</td><td><span class="badge badge-success">Active</span></td><td><button class="btn-outline" style="padding:4px 12px;" onclick="alert('Edit user (demo)')">Edit</button></td></tr>
              <tr><td>ADM022</td><td>Rakesh Gupta</td><td>Accountant</td><td>Finance</td><td><span class="badge badge-success">Active</span></td><td><button class="btn-outline" style="padding:4px 12px;" onclick="alert('Edit user (demo)')">Edit</button></td></tr>
              <tr><td>PHT2026001</td><td>Kavya Mishra</td><td>Student</td><td>B.Pharm</td><td><span class="badge">Pending</span></td><td><button class="btn-outline" style="padding:4px 12px;" onclick="alert('Approve (demo)')">Approve</button></td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- 3. COURSE MANAGEMENT VIEW -->
    <div id="courseManagementView" class="view">
      <div class="page-title">Course Management</div>
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-label">B.Pharm</div><div class="stat-number">8</div></div>
        <div class="stat-card"><div class="stat-label">M.Pharm</div><div class="stat-number">4</div></div>
        <div class="stat-card"><div class="stat-label">Pharm.D</div><div class="stat-number">2</div></div>
        <div class="stat-card"><div class="stat-label">D.Pharm</div><div class="stat-number">2</div></div>
      </div>
      <div class="card">
        <div class="card-title">Course List & Faculty Assignment</div>
        <div style="margin-bottom:16px;">
          <button class="btn-primary" onclick="alert('Add new course (demo)')"><i class="fas fa-plus-circle"></i> Add Course</button>
        </div>
