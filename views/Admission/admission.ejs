<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADMISSION OPEN</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
 <link rel="stylesheet" href="css/admission.css">
</head>
<body>
    <div class="container">
        <!-- Top Banner -->
       
        
        <!-- Header -->
        <div class="header">
            <div class="logo">
                <div class="logo-icon">
                    <i class="fas fa-graduation-cap"></i>
                </div>
                
            </div>
            <div class="contact-info">
                <div><i class="fas fa-phone"></i> +91-9876543210</div>
                <div><i class="fas fa-envelope"></i> info@educare.edu</div>
            </div>
        </div>
        
      
        
        <!-- NRI Section -->
        <div class="nri-section">
            <div class="nri-text">
                <i class="fas fa-globe-americas"></i>
                Did You Hear About maa matuarni Pharmacy college  Admissions?
            </div>
            <div class="open-badge">
                OPEN
            </div>
        </div>
        
        <!-- Form Section -->
        <div class="form-section">
            <div class="form-title">
                <h2>ADMISSION APPLICATION FORM</h2>
                <p>Fill the form below to apply for admission</p>
            </div>
            
            <form id="admissionForm">
                <div class="form-container">
                    <div class="form-group">
                        <label><i class="fas fa-user"></i> Full Name *</label>
                        <i class="input-icon fas fa-user-circle"></i>
                        <input type="text" placeholder="Enter your full name" required>
                    </div>
                    
                    <div class="form-group">
                        <label><i class="fas fa-user-friends"></i> Father's Name *</label>
                        <i class="input-icon fas fa-user-tie"></i>
                        <input type="text" placeholder="Enter father's name" required>
                    </div>
                    
                    <div class="form-group">
                        <label><i class="fas fa-phone"></i> Mobile Number *</label>
                        <i class="input-icon fas fa-mobile-alt"></i>
                        <input type="tel" placeholder="10-digit mobile number" required>
                    </div>
                    
                    <div class="form-group">
                        <label><i class="fas fa-envelope"></i> Email Address *</label>
                        <i class="input-icon fas fa-at"></i>
                        <input type="email" placeholder="example@gmail.com" required>
                    </div>
                    
                    <div class="form-group">
                        <label><i class="fas fa-calendar"></i> Date of Birth *</label>
                        <i class="input-icon fas fa-birthday-cake"></i>
                        <input type="date" required>
                    </div>
                    
                    <div class="form-group">
                        <label><i class="fas fa-venus-mars"></i> Gender *</label>
                        <i class="input-icon fas fa-user"></i>
                        <select required>
                            <option value="">Select Gender</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                    </div>
                    
                    <div class="form-group full-width">
                        <label><i class="fas fa-map-marker-alt"></i> Address *</label>
                        <i class="input-icon fas fa-home"></i>
                        <input type="text" placeholder="Complete address with city and pincode" required>
                    </div>
                    
                    <div class="form-group">
                        <label><i class="fas fa-book"></i> Course Interested *</label>
                        <i class="input-icon fas fa-graduation-cap"></i>
                       <select class="form-control" id="course" name="course">
                      <option value="" disabled selected>-- Select your preferred program --</option>
                      <option value="Bachelor of Arts">BA</option>
                      <option value="Bachelor of Pharmacy">B.Pharm</option>
                      <option value="Diploma in Pharmacy">D.Pharm</option>
                      <option value="Auxiliary Nurse Midwifery">ANM</option>
                      <option value="General Nursing and Midwifery">GNM</option>
                      <option value="Diploma in Elementary Education">D.El.Ed</option>
                     <option value="Other">Other / Not sure</option>
                   </select>

                    </div>
                    
                    <div class="form-group">
                        <label><i class="fas fa-school"></i> 12th Percentage *</label>
                        <i class="input-icon fas fa-percentage"></i>
                        <input type="number" step="0.01" placeholder="Enter percentage" required>
                    </div>
                </div>
                
                <button type="submit" class="submit-btn">
                    <i class="fas fa-paper-plane"></i> SUBMIT ADMISSION FORM
                </button>
                
                <div class="success-message" id="successMsg">
                    <i class="fas fa-check-circle"></i>
                    <h3>ADMISSION FORM SUBMITTED SUCCESSFULLY!</h3>
                    <p>Our team will contact you within 24 hours.</p>
                </div>
            </form>
        </div>
        
      <script src="/js/admission.js"></script>
    
      
</body>
</html>