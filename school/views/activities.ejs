<!-- footer simulation (partial) -->
<div class="footer-sim">
  <div class="inner">
    <span>© 2026 MSD Public School. All rights reserved.</span>
    <span class="social">
      <i class="fab fa-facebook"></i>
      <i class="fab fa-instagram"></i>
      <i class="fab fa-youtube"></i>
      <i class="fab fa-twitter"></i>
    </span>
  </div>
</div>

<!-- filtering script -->
<script>
  (function() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.activity-card');

    function filterActivities(category) {
      cards.forEach(card => {
        const cardCat = card.getAttribute('data-category');
        if (category === 'all' || cardCat === category) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
    }

    // set active class on filter buttons
    filterBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        filterBtns.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const filter = this.getAttribute('data-filter');
        filterActivities(filter);
      });
    });

    // "Join" button click feedback
    document.querySelectorAll('.btn-detail').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        alert('🎉 You are interested! We will contact you with more details.');
      });
    });

    // CTA register button
    document.querySelector('.btn-join').addEventListener('click', function() {
      alert('📋 Registration form will open soon. Stay tuned!');
    });

  })();
</script>
<%-include("partials/footer.ejs") %>

