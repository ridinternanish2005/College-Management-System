<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Feedback | Bright Future School</title>
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/school/css/feedback.css">


</head>
<body>
  <%- include("partials/navbar.ejs") %>
<div class="container">
    <div class="feedback-card">
        <div class="card-header">
            <h2><i class="fas fa-comment-dots"></i> Share Your Feedback</h2>
            <p>We value your opinion. Let us know about your experience with our school.</p>
            <div class="badge"><i class="fas fa-star"></i> Your voice matters to us</div>
        </div>
        <div class="form-body">
           <form id="feedbackForm" action="/feedback" method="POST" novalidate>

    <div class="form-group">
        <label><i class="fas fa-user"></i> Your Name *</label>

        <input 
            type="text"
            id="name"
            name="name"
            placeholder="e.g., Riya Mehta"
            required
        >
    </div>

    <div class="form-group">
        <label><i class="fas fa-envelope"></i> Email Address *</label>

        <input 
            type="email"
            id="email"
            name="email"
            placeholder="you@example.com"
            required
        >
    </div>

    <div class="form-group">
        <label><i class="fas fa-chalkboard-user"></i> Relation to School *</label>

        <select id="relation" name="relation" required>
            <option value="" disabled selected>-- Select --</option>

            <option value="Parent">Parent</option>
            <option value="Student">Student</option>
            <option value="Alumni">Alumni</option>
            <option value="Teacher">Teacher</option>
            <option value="Community Member">Community Member</option>
        </select>
    </div>

    <div class="form-group">
        <label><i class="fas fa-star"></i> Your Rating *</label>

        <div class="rating-group">

            <div class="stars" id="starRating">
                <i class="far fa-star" data-value="1"></i>
                <i class="far fa-star" data-value="2"></i>
                <i class="far fa-star" data-value="3"></i>
                <i class="far fa-star" data-value="4"></i>
                <i class="far fa-star" data-value="5"></i>
            </div>

            <input 
                type="hidden"
                id="ratingValue"
                name="rating"
                value="0"
            >

            <div class="rating-label" id="ratingText">
                Click a star to rate
            </div>

        </div>
    </div>

    <div class="form-group">
        <label><i class="fas fa-comment"></i> Your Feedback / Suggestions *</label>

        <textarea 
            id="feedbackMsg"
            name="message"
            rows="4"
            placeholder="Please share your valuable feedback, suggestions, or any concerns..."
            required
        ></textarea>
    </div>

    <button type="submit" class="btn-submit">
        <i class="fas fa-paper-plane"></i> Submit Feedback
    </button>

    <div id="formStatus" class="status-message" style="display: none;"></div>

</form>
            <div class="info-footer">
                <i class="fas fa-lock"></i> Your feedback is anonymous to the public and will be used for internal improvement.
                <i class="fas fa-smile" style="margin-left: 12px;"></i> Thank you for helping us serve better.
            </div>
        </div>
    </div>
</div>

<script src="/school/js/Feedback.js" defer></script>



<%-include("partials/footer.ejs") %>
</body>
</html>